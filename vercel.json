{
  "buildCommand": "rm -rf .next && npm run build",
  "regions": ["icn1"],
  "crons": [
    {
      "path": "/api/emails/reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/recapture-holds",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/cron/capture-tour-day-payments",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/analytics-refresh-views",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/analytics-anonymize",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/rag-reindex",
      "schedule": "30 16 * * *"
    },
    {
      "path": "/api/cron/rag-harvest",
      "schedule": "30 15 * * 1"
    },
    {
      "path": "/api/cron/tour-room-flywheel",
      "schedule": "0 16 * * 1"
    },
    {
      "path": "/api/cron/ops-daily-report",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/tours/:id",
      "destination": "/api/tours/[id]"
    },
    {
      "source": "/api/tours/:id/availability",
      "destination": "/api/tours/[id]/availability"
    },
    {
      "source": "/api/tours/:id/availability/range",
      "destination": "/api/tours/[id]/availability/range"
    }
  ]
}








# Claude Code agent data — worktrees + session transcripts (~3GB)
# Pattern: ignore directory CONTENTS (not the dir itself) so we can re-include
# specific subpaths below. Once a directory is fully ignored, negation patterns
# inside it stop working — known git limitation.
/.claude/*
# Exception: project-level skills are versioned alongside the code they describe
!/.claude/skills/

# generated / scratch script artifacts
scripts/*.log
scripts/translate_queue*.json

# data pipeline: large/generated files (GitHub 100MB limit)
atoc-data-pipeline/visitkorea.nt
atoc-data-pipeline/**/places.db
atoc-data-pipeline/**/__pycache__/
atoc-data-pipeline/lod/etl_log.txt
atoc-data-pipeline/lod/etl_progress.txt
atoc-data-pipeline/lod/etl_error_log.txt
atoc-data-pipeline/lod/etl_skipped_lines.log
atoc-data-pipeline/output/
/nul

{
  "name": "atockorea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Removed .next')}catch(e){console.log('No .next to remove')}\"",
    "dev": "next dev -H 0.0.0.0 --webpack",
    "dev:clean": "npm run clean && npm run dev",
    "build": "node scripts/build-catalog-cards.mjs && next build --webpack",
    "build:mobile": "BUILD_FOR_MOBILE=true next build",
    "start": "next start",
    "lint": "eslint \"components/home/v2\" \"lib/home\" \"app/api/reviews/home-summary\" --max-warnings 0",
    "lint:full": "next lint --max-warnings 200",
    "icons:sync": "node scripts/sync-app-icons-from-svg.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "analyze": "ANALYZE=true next build",
    "create-merchant": "node scripts/create-merchant.js",
    "seed:places": "echo Run: curl -X POST http://localhost:3000/api/admin/seed-places-overviews -H \"x-seed-secret: $SEED_PLACES_SECRET\"",
    "poi:locales:enrich": "node --env-file=.env.local scripts/enrich-match-pois-locales-from-tour-jsons.mjs",
    "poi:photos:sync": "node --env-file=.env.local scripts/sync-match-poi-photos-with-tour-jsons.mjs",
    "mobile:setup": "node scripts/setup-react-native.sh",
    "android:add": "npx cap add android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "match:regression": "npx tsx scripts/match-regression.ts",
    "match:regression:strict": "npx tsx scripts/match-regression.ts --strict",
    "match:haiku-live": "npx tsx scripts/match-haiku-live.ts",
    "match:stress": "npx tsx scripts/match-stress.ts",
    "match:stress:haiku": "npx tsx scripts/match-stress.ts --parser=haiku",
    "match:stress:failed": "npx tsx scripts/match-stress.ts --only-failed",
    "match:stress:cat": "npx tsx scripts/match-stress.ts --category",
    "itinerary:profiles:migration": "npx tsx scripts/generate-itinerary-builder-poi-profile-migration.ts",
    "itinerary:profiles:migration:check": "npx tsx scripts/generate-itinerary-builder-poi-profile-migration.ts --check",
    "itinerary:pressure": "npx tsx scripts/itinerary-builder-pressure-test.ts",
    "visitjeju:search": "npx tsx scripts/visitjeju-search.ts",
    "jeju:unsplash-fill": "npx tsx scripts/jeju-tour-fill-unsplash-images.ts",
    "atoc:apply-locale-zip": "npx tsx scripts/apply-atoc-locale-bundle.ts",
    "stress:noshow": "npx tsx scripts/stress-noshow-hold.ts",
    "import:match-v18": "node scripts/import-match-v18.mjs",
    "chat:classify": "node scripts/classify-chat-messages.mjs",
    "gen:southwest-tour-product-zh-TW-sql": "node scripts/gen-southwest-tour-product-zh-TW-sql.mjs",
    "gen:southwest-tour-product-zh-CN-sql": "node scripts/gen-southwest-tour-product-zh-CN-sql.mjs",
    "gen:southwest-tour-product-ko-sql": "node scripts/gen-southwest-tour-product-ko-sql.mjs",
    "gen:southwest-tour-product-ja-sql": "node scripts/gen-southwest-tour-product-ja-sql.mjs",
    "gen:southwest-tour-product-es-sql": "node scripts/gen-southwest-tour-product-es-sql.mjs",
    "gen:jeju-grand-highlights-tour-product-zh-TW-sql": "node scripts/gen-jeju-grand-highlights-tour-product-zh-TW-sql.mjs",
    "gen:jeju-grand-highlights-tour-product-zh-CN-sql": "node scripts/gen-jeju-grand-highlights-tour-product-zh-CN-sql.mjs",
    "gen:jeju-grand-highlights-tour-product-ja-sql": "node scripts/gen-jeju-grand-highlights-tour-product-ja-sql.mjs",
    "gen:jeju-grand-highlights-tour-product-es-sql": "node scripts/gen-jeju-grand-highlights-tour-product-es-sql.mjs",
    "gen:jeju-grand-highlights-tour-product-ko-sql": "node scripts/gen-jeju-grand-highlights-tour-product-ko-sql.mjs",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:link": "supabase link",
    "db:pull": "supabase db pull",
    "db:push": "supabase db push",
    "db:diff": "supabase db diff --linked",
    "db:reset": "supabase db reset",
    "db:exec": "supabase db query --linked",
    "db:types": "supabase gen types typescript --linked --schema public > lib/database.types.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",

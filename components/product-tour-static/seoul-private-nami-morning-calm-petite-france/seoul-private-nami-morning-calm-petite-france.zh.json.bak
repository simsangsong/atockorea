    {
      "id": "itinerary",
      "section_html_id": "itinerary",
      "component": "TourTimelineSection",
      "props": {
        "itineraryStops": [
          {
            "number": 1,
            "time": "10:30",
            "duration": "180分钟",
            "name": "南怡岛（南怡洲）",
            "category": "渡轮小岛&韩剧地标",
            "description": "南怡岛以5分钟渡轮从加平码头出发，登上北汉江中一座形似半月的河中小岛。面积约**46万平方米、周长约5公里**，以朝鲜时代军事将领**南怡（1441至1468年）**命名。2002年，南怡岛因成为KBS剧集**《冬季恋歌》**（裴勇俊、崔志友主演）的拍摄地而享誉全球——成为2000年代初韩流浪潮的催化剂——每年至今仍吸引约**330万人次**（其中130万名外籍旅客）。自**2006年3月1日**起，岛屿以「**南怡共和国**」的名义进行自我品牌建设，设有专属旗帜、货币（硬币）、护照和邮政服务（旅游行销概念）。代表性的**水杉大道**（《冬季恋歌》经典雪中小径）、**银杏恋人道**、**韩国红松道**，以及用烧酒瓶制成的再生玻璃红杉桥，都可在轻松的半日游中步行游览。",
            "highlights": [
              "半月形河中小岛，约46万平方米 / 周长5公里；以将领南怡（1441至1468年）命名",
              "代表性水杉大道 — 《冬季恋歌》（2002年）经典拍摄地",
              "自2006年起自称「南怡共和国」 — 设有旗帜、货币、护照（旅游概念）",
              "从加平码头搭乘5分钟渡轮（每10至20分钟一班）",
              "岛上野生动物：孔雀（含罕见白化孔雀）、鸵鸟、野兔、松鼠",
              "**1944年清平水坝建成**使南怡成为永久岛屿",
              "**2006年3月1日宣布成立南怡共和国** — 韩国第一个微型旅游共和国概念",
              "**UNI年F儿童友善公园2010年认定** + 每年600多场表演/展览/节庆",
              "**入场费**：正常渡轮₩19,000来回；36个月以下婴儿免费"
            ],
            "timeUsed": [
              "从加平码头乘渡轮（含排队5–10分钟）",
              "沿水杉/银杏/韩国松大道自由漫步",
              "可选：租借自行车（单人₩7,000/双人₩14,000/小时）",
              "岛上午餐（Sonata 咖啡馆、糖饼、红薯拿铁、韩式牛肉饼等）",
              "乘渡轮返回码头"
            ],
            "whyOnRoute": "**南怡岛排在最前**，利用最强的早晨光线进行林荫步道摄影，同时避开下午最重的渡船排队人潮。在全日体力最充沛时在岛上停留，也让后续的晨静树木园和小法国村在更轻松的节奏下进行。私人包车跳过了加平接驳巴士（每30至60分钟一班）的等候时间，为南怡岛多争取了1至2小时的有效游览时间。",
            "visitBasics": {
              "hours": "岛上08:00–21:00（末班渡轮时间变动）；岛内大部分店铺约18:00打烊",
              "closed": "全年开放",
              "admission": "纳米纳拉共和国签证费（含往返渡轮）：普通₩19,000/优惠₩13,000",
              "walking": "轻松——平坦林荫大道；全程约5公里。可租自行车/电动车"
            },
            "convenience": {
              "restroom": "岛上多处及加平码头设有厕所",
              "parking": "加平码头小型车₩6,000/大型车₩10,000"
            },
            "smartNotes": {

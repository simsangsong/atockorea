  "staticQuestions": [
    {
      "id": "q-vs-unesco-legacy",
      "question": "(Consulte las preguntas frecuentes al reservar)",
      "answer": "Para más información, contacte a AtoC Korea al reservar."
    },
    {
      "id": "q-bridge-night-view",
      "question": "¿Veremos el puente iluminado?",
      "answer": "El C3 llega a Woljeonggyo ~17:00-17:30, durante la hora dorada antes del encendido completo. El C2 llega ~17:30-18:00 con luz más baja. En los días más cortos (invierno), el C3 puede llegar justo al encendido."
    },
    {
      "id": "q-bulguksa-only",
      "question": "¿Por qué no está la Gruta Seokguram?",
      "answer": "Seokguram requiere 40 min adicionales de desvío desde Bulguksa y no encaja en un tour de un día desde Busan sin comprometer el tiempo de calidad en las demás paradas."
    },
    {
      "id": "q-admissions",
      "question": "¿Las entradas están incluidas?",
      "answer": "Sí. Todas incluidas: Bulguksa (₩6.000), Museo Nacional (gratuito), Ahopsan/Gyochon/Woljeonggyo (gratuitos)."
    },
    {
      "id": "q-museum-language",
      "question": "¿Hay señalización en inglés en el museo?",
      "answer": "Sí. Señalización bilingüe coreano/inglés en las piezas principales."
    },
    {
      "id": "q-bulguksa-photography",
      "question": "¿Se puede fotografiar en Bulguksa?",
      "answer": "Sí en todas las áreas exteriores. El interior de los pabellones puede tener restricciones."
    },
    {
      "id": "q-vegetarian",
      "question": "¿Hay opciones vegetarianas para el almuerzo?",
      "answer": "Sí. El ssambap puede prepararse sin carne a petición. Comuníquelo al guía al reservar."
    },
    {
      "id": "q-rain",
      "question": "¿Qué pasa si llueve?",
      "answer": "El tour sigue normalmente. Con tifón: cancelación con reembolso."
    },
    {
      "id": "first-time",
      "question": "¿Es buena opción para quienes visitan Gyeongju por primera vez?",
      "answer": "Sí — cubre las seis paradas más representativas a ritmo cómodo. Ideal si quiere absorber cada lugar sin correr."
    },
    {
      "id": "walking",
      "question": "¿Cuánto hay que caminar?",
      "answer": "Moderado. Total: ~4-5 km. Mismas paradas que el C2 pero con más tiempo de descanso entre ellas."
    },
    {
      "id": "family",
      "question": "¿Es adecuado para familias?",
      "answer": "Sí para familias con niños de 8+ años. El ritmo más pausado es especialmente conveniente para familias con niños."
    },
    {
      "id": "seniors",
      "question": "¿Pueden participar personas mayores cómodamente?",
      "answer": "Sí. El ritmo más pausado del C3 es la opción preferida para personas mayores activas."
    },
    {
      "id": "children",
      "question": "¿Cuál es la edad mínima recomendada?",
      "answer": "A partir de 8 años para aprovechar el contenido."
    }
  ],

    "_seasonalSummary": "Gyeongju está en el interior del sureste de Corea: inviernos algo más fríos que Busan y veranos más calurosos. Primavera y otoño son las estaciones más cómodas."
  },
  "seasonalVariations": [
    {
      "season": "Primavera (mediados mar a mediados abr)",
      "description": "tiempo previsto de cerezos: Ahopsan puede cambiar por Haeundae Dalmaji. Bulguksa con cerezos tardíos en abril."
    },
    {
      "season": "Verano (jun-ago)",
      "description": "El bambú ofrece sombra fresca. El museo tiene aire acondicionado. El ritmo pausado es especialmente cómodo en verano."
    },
    {
      "season": "Otoño (finales sep a finales oct)",
      "description": "El follaje de Bulguksa en octubre es uno de los más fotografiados de Corea."
    },
    {
      "season": "Invierno (nov-feb)",
      "description": "Menos visitantes. Regreso más temprano conveniente para el corto día de invierno."
    }
  ],

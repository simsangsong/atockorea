    {
      "id": "faq",
      "section_html_id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "q-vs-unesco-legacy",
            "question": "'유네스코 레거시 투어(부산 출발)'와 어떻게 다른가요?",
            "answer": "두 투어 모두 아홉산 → 불국사 → 박물관 → 교촌 → 월정교 동일 코스입니다. '고도 투어'는 일정 속도가 더 여유롭고 부산에 더 일찍 귀환합니다. '유네스코 레거시'는 박물관 체류 시간이 더 길고 심층 가이드가 제공됩니다."
          },
          {
            "id": "q-bridge-night-view",
            "question": "월정교 야간 조명을 볼 수 있나요?",
            "answer": "이 투어에서는 대부분의 경우 어렵습니다. 월정교는 일몰 후 조명이 켜지지만, 이 코스는 일몰 전 월정교에 도착합니다."
          },
          {
            "id": "q-bulguksa-only",
            "question": "석굴암은 왜 포함되지 않나요?",
            "answer": "석굴암은 불국사와 같은 유네스코 등재이지만 산 위 8km 거리에 위치, 좁은 주차와 긴 이동 시간으로 당일 일정에 포함하기 어렵습니다."
          },
          {
            "id": "q-admissions",
            "question": "입장료가 포함되어 있나요?",
            "answer": "아홉산숲(₩5,000, 현장 지불)만 별도입니다. 불국사(2023년 5월부터 무료), 국립경주박물관·교촌·월정교는 무료입니다."
          },
          {
            "id": "q-museum-language",
            "question": "박물관 내 영어 안내가 있나요?",
            "answer": "네, 3개 상설전시관 전체에 영어·중국어 전시 패널이 있습니다."
          },
          {
            "id": "q-bulguksa-photography",
            "question": "불국사에서 사진을 찍을 수 있나요?",
            "answer": "네, 경내 전체에서 가능합니다. 플래시와 삼각대는 피해 주세요."
          },
          {
            "id": "q-vegetarian",
            "question": "채식 점심 옵션이 있나요?",
            "answer": "네, 경주 쌈밥 정식은 채소 반찬이 많아 고기 없이도 식사 구성이 가능합니다. 현장에서 가이드가 안내해 드립니다."
          },
          {
            "id": "q-rain",
            "question": "비가 오면 어떻게 되나요?",
            "answer": "가벼운 비: 예정대로 진행. 강우 시: 불국사 계단 미끄럼 주의, 아홉산 길 진흙 상태 가능. 박물관·교촌은 대부분 진행 가능."
          },
          {
            "id": "first-time",
            "question": "경주를 처음 방문하는 분에게 적합한가요?",
            "answer": "네, 경주 핵심 명소를 여유 있는 일정 속도로 방문할 수 있습니다. 유네스코 문화유산을 원하는 첫 방문자에게 적합합니다."
          },
          {
            "id": "walking",
            "question": "도보 이동이 얼마나 되나요?",
            "answer": "약 3.5~4km. 불국사가 가장 활동적인 구간(고르지 않은 석재). 박물관은 실내 평지. 교촌·월정교는 가볍습니다."
          },
          {
            "id": "family",
            "question": "가족 여행에 적합한가요?",
            "answer": "만 8세 이상, 하루 일정을 소화할 수 있는 어린이에게 적합합니다."
          },
          {
            "id": "seniors",

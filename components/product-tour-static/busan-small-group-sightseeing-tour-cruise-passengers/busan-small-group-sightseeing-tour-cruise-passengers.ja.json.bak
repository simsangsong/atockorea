    {
      "id": "faq",
      "section_html_id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "q-cruise-busy-day",
            "question": "混雑するクルーズ寄港日はツアーが満員になりますか？",
            "answer": "少人数制（最大8名）のため、早めのご予約をお勧めします。複数のクルーズ船が同日に寄港する日は特に早めの予約が重要です。"
          },
          {
            "id": "q-early-arrival",
            "question": "船が非常に早く到着した場合でも参加できますか？",
            "answer": "はい。到着時刻に合わせてピックアップ時間を調整します。早朝到着の場合はご予約時にお知らせください。"
          },
          {
            "id": "q-lunch",
            "question": "昼食は含まれていますか？",
            "answer": "はい。昼食はツアー代金に含まれています（地元の釜山レストランで）。ベジタリアン・ハラール対応は予約時にお申し出ください。"
          },
          {
            "id": "q-vs-private-cruise",
            "question": "プライベート釜山クルーズツアーとの違いは何ですか？",
            "answer": "このツアーは少人数（最大8名）のシェアバン形式です。プライベートツアーはグループ専用の車両とガイドを使用し、ルートを完全にカスタマイズできます。プライベートの柔軟性を優先する場合は釜山プライベートカーチャーターツアーをご検討ください。"
          },
          {
            "id": "q-gamcheon-stairs",
            "question": "甘川の坂道がきつかった場合はどうなりますか？",
            "answer": "ガイドが甘川の入口付近でお待ちすることもできます。主要なフォトゾーン（展望台・星の王子さまの彫刻）への最短ルートを案内しますので、全ての坂道を歩く必要はありません。"
          },
          {
            "id": "q-customize",
            "question": "行程をカスタマイズできますか？",
            "answer": "シェアバンツアーのため行程の変更は難しいですが、事前にご要望がある場合はご相談ください。完全なカスタマイズを希望される場合はプライベートカーチャーターをお勧めします。"
          },
          {
            "id": "q-tower-tickets",
            "question": "釜山タワーの展望台チケットは含まれていますか？",
            "answer": "予約時にご確認ください。標準価格には含まれない場合があります（大人₩12,000）。ガイドが現地での購入をサポートします。"
          },
          {
            "id": "q-taejongdae-train",
            "question": "太宗台のダヌビ観光列車に乗るべきですか？",
            "answer": "ダヌビ列車（別途有料）は太宗台の観光ルートを30〜40分で一周する便利な乗り物です。時間に余裕がある場合はおすすめです。ガイドが当日の状況に合わせてアドバイスします。"
          },
          {
            "id": "q-jagalchi-eat",
            "question": "昼食をチャガルチ市場で食べることはできますか？",
            "answer": "昼食はツアーに含まれており、ガイドが手配した地元レストランでお取りいただく形式です。チャガルチでは一日の最後に軽い海産物スナック（オデンなど）を楽しむことをお勧めします。"
          },
          {
            "id": "first-time",
            "question": "釜山初訪問者に良い選択ですか？",
            "answer": "はい。国連記念公園・太宗台・甘川・龍頭山・チャガルチという釜山の多様な側面を一日でカバーできる、釜山の良い入門ツアーです。"
          },
          {
            "id": "walking",
            "question": "歩行量はどれくらいですか？",
            "answer": "中程度。総歩行距離は約3〜4km。最もアクティブな区間は甘川文化村の丘の路地（急坂あり）です。太宗台は遊歩道またはダヌビ列車で対応可能。歩きやすいクローズドトゥシューズを推奨します。"
          },
          {
            "id": "family",
            "question": "お子様連れのファミリーに適していますか？",
            "answer": "はい。6歳以上のお子様がいるファミリーに適しています。甘川の坂道が唯一の難所です。チャガルチの活魚コーナーは子供に人気です。"
          },
          {
            "id": "seniors",
            "question": "高齢の方でも快適に参加できますか？",
            "answer": "はい、活動的な高齢者の方はご参加いただけます。太宗台はダヌビ列車でも対応でき、甘川はゆっくり自分のペースで歩けます。"
          },
          {
            "id": "children",
            "question": "推奨される最低年齢は？",
            "answer": "6歳以上が最適です。9時間の寄港地ツアーのリズムについてこられれば参加できます。"
          },
          {
            "id": "weather",
            "question": "大雨や台風の場合はどうなりますか？",
            "answer": "大雨や台風で寄港地が変更になった場合は全額返金いたします。小雨ではツアーは通常通り実施されます。"
          }
        ]
      }

  "seasonalVariations": [
    {
      "season": "Primavera (mar-may)",
      "description": "Flores de cerezo en Yongdusan Park y alrededores. Temperatura recomendado para las escaleras de Gamcheon."
    },
    {
      "season": "Verano (jun-ago)",
      "description": "Largas jornadas de luz. Taejongdae y Jagalchi con actividad máxima."
    },
    {
      "season": "Otoño (sep-nov)",
      "description": "Mejor visibilidad desde el observatorio de la Torre de Busan. Posibles vistas a Tsushima desde Taejongdae."
    },
    {
      "season": "Invierno (dic-feb)",
      "description": "Menos turistas en Gamcheon. El Memorial ONU especialmente recogido. Mariscos de temporada fría en Jagalchi."
    }

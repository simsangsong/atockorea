    "_seasonalSummary": "Busan es la gran ciudad más meridional de Corea del Sur: más templada y lluviosa que Seúl, con inviernos suaves (mínimas de 5–10 °C). El verano es húmedo, con el pico de lluvias durante el monzón de julio.",
    "_seasonalTemperatures": [
      {
        "season": "Primavera (mar.–may.)",
        "range": "8–22 °C",
        "notes": "Cherry blossoms in late March / early April."
      },
      {
        "season": "Verano (jun.–ago.)",
        "range": "22–30 °C",
        "notes": "Caluroso y húmedo; en julio puede llover por el monzón. La brisa marina hace que Taejongdae se sienta más agradable."
      },
      {
        "season": "Otoño (sep.–nov.)",
        "range": "10–24 °C",
        "notes": "Mejor temporada: aire más limpio y mar más templado. Follaje otoñal a finales de octubre."
      },
      {
        "season": "Invierno (dic.–feb.)",
        "range": "0–10 °C",
        "notes": "Suave para Corea, aunque puede hacer viento en las paradas costeras."
      }
    ]

    {
      "id": "faq",
      "section_html_id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "q-cruise-busy-day",
            "question": "¿Estará llena la furgoneta en días de mucho crucero?",
            "answer": "Priorizamos regresar de forma segura al puerto con al menos 60-90 minutos de margen antes de la hora límite de embarque del crucero. El itinerario, los tiempos de visita y la hora de regreso se ajustan según el horario real del barco. Si hay tráfico, mal tiempo o retrasos en el desembarque, el guía reducirá el tiempo en algunas paradas para priorizar el regreso seguro al puerto y llegar a tiempo para volver a embarcar."
          },
          {
            "id": "q-early-arrival",
            "question": "(Consulte las preguntas frecuentes al reservar)",
            "answer": "Para más información, contacte a AtoC Korea al reservar."
          },
          {
            "id": "q-lunch",
            "question": "¿El almuerzo está incluido?",
            "answer": "Sí. El almuerzo está incluido en el precio del tour — uno de los pocos tours de excursión de crucero en Busan que lo incluye. El menú habitual es dwaeji gukbap (sopa de cerdo de Busan) o haemul jeongsik (menú de marisco)."
          },
          {
            "id": "q-vs-private-cruise",
            "question": "¿En qué se diferencia de un tour privado de crucero en Busan?",
            "answer": "Este tour compartido (máx. ~10) ofrece el mejor relación calidad-precio para grupos de 1-3 personas. Un tour privado en coche es más flexible en horarios y ruta, pero más caro. Para grupos de 4+ personas, el tour privado puede ser más económico por persona."
          },
          {
            "id": "q-gamcheon-stairs",
            "question": "¿Qué pasa si las escaleras de Gamcheon son demasiado para mí?",
            "answer": "El guía puede adaptar el recorrido de Gamcheon. Hay rutas alternativas más llanas dentro del barrio que evitan los tramos más empinados."
          },
          {
            "id": "q-customize",
            "question": "¿Puedo personalizar el itinerario?",
            "answer": "No. Es un tour compartido con itinerario fijo. Para personalización, elija el tour privado."
          },
          {
            "id": "q-tower-tickets",
            "question": "¿Está incluida la entrada al observatorio de la Torre de Busan?",
            "answer": "Sí. La entrada al observatorio de la Torre de Busan (₩15.000) está incluida en el precio del tour."
          },
          {
            "id": "q-taejongdae-train",
            "question": "¿Deberíamos tomar el Tren Danubi en Taejongdae?",
            "answer": "El Tren Danubi (~₩3.000, no incluido) es una opción para quienes prefieren no caminar el sendero. El guía le informará de la disponibilidad en el momento."
          },
          {
            "id": "q-jagalchi-eat",
            "question": "¿Podemos comer en Jagalchi en lugar del restaurante del almuerzo?",
            "answer": "El almuerzo está incluido en un restaurante precontratado. Comer marisco adicional en Jagalchi (opcional, pago directo) es posible realizar en la parada de Jagalchi al final del día."
          },
          {
            "id": "first-time",
            "question": "¿Es buena opción para quienes visitan Busan por primera vez?",
            "answer": "Sí — cubre los cinco puntos más representativos de Busan en 9 horas, con regreso seguro al crucero."
          },
          {
            "id": "walking",
            "question": "¿Cuánto hay que caminar?",
            "answer": "Moderado. Total: ~4-5 km. Gamcheon tiene escaleras (~100-120 escalones). Taejongdae tiene el Tren Danubi como alternativa. Memorial ONU, Torre de Busan y Jagalchi son llanos o con acceso por ascensor."
          },
          {
            "id": "family",
            "question": "¿Es adecuado para familias con niños?",
            "answer": "Sí para niños de 8+ años. Gamcheon tiene escaleras. Taejongdae tiene el Tren Danubi para evitar el sendero."
          },
          {
            "id": "seniors",
            "question": "¿Pueden participar personas mayores cómodamente?",
            "answer": "Sí para mayores activos. Gamcheon es la sección más exigente. El guía puede adaptar el recorrido. El Tren Danubi es una alternativa al sendero de Taejongdae."
          },
          {
            "id": "children",
            "question": "¿Cuál es la edad mínima recomendada?",
            "answer": "A partir de 8 años para el ritmo de la excursión."
          },
          {
            "id": "weather",
            "question": "¿Qué pasa con lluvia intensa o tifón?",
            "answer": "Lluvia ligera: el tour sigue normalmente. Tifón o cancelación del crucero: reembolso total. Si el barco no puede atracar, se reembolsa íntegramente."
          }
        ]
      }

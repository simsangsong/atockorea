  "bookingTrustItems": [
    {
      "icon": "check-circle",
      "title": "Equipo local certificado",
      "description": "Operador turístico coreano autorizado con seguro completo",
      "iconBg": "bg-emerald-50/80",
      "iconColor": "text-emerald-600",
      "body": "Regreso seguro al Puerto de Busan al menos 60 minutos antes de la salida del barco. Operador certificado con experiencia en excursiones de crucero."
    },
    {
      "icon": "route",
      "title": "Especialistas en excursiones de crucero",
      "description": "Itinerario ajustado a medida, no un circuito genérico",
      "iconBg": "bg-sky-50/80",
      "iconColor": "text-sky-600",
      "body": "Priorizamos regresar de forma segura al puerto con al menos 60-90 minutos de margen antes de la hora límite de embarque del crucero. El itinerario, los tiempos de visita y la hora de regreso se ajustan según el horario real del barco. Si hay tráfico, mal tiempo o retrasos en el desembarque, el guía reducirá el tiempo en algunas paradas para priorizar el regreso seguro al puerto y llegar a tiempo para volver a embarcar."
    },
    {

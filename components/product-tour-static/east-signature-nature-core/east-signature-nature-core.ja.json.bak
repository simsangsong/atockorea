  "staticQuestions": [
    {
      "id": "first-time",
      "question": "済州初訪問者にとってこのルートは良い選択ですか？",
      "answer": "はい — 石の文化・海岸・火山・溶岩洞窟・民俗村という5つの異なる体験タイプを一日で網羅できます。どのタイプが自分に合うかまだわからない初訪問者にとって、東済州全体をバランスよく概観できる理想的なルートです。"
    },
    {
      "id": "walking",
      "question": "このルートは疲れますか？",
      "answer": "アクティブですが、ハードではありません。城山日出峰の山頂登頂（任意）が最も体力を使うセクションです。その他の見どころは整備された遊歩道が多く、一般的な体力の方であれば問題ありません。"
    },
    {
      "id": "rain",
      "question": "雨天でも催行されますか？",
      "answer": "はい — ほとんどの天候条件で催行します。悪天候時は城山日出峰の山頂登頂が中止になる場合がありますが、ツアー自体は続行します。出発12時間前に状況をお知らせします。"
    },
    {
      "id": "parents",
      "question": "親を連れての参加に適していますか？",
      "answer": "緩やかなペースで歩けるご両親には向いています。各訪問地にベンチや休憩エリアがあります。城山日出峰の登頂は任意のため、体力に合わせて選択できます。"
    },
    {
      "id": "children",
      "question": "子供を連れて参加できますか？",
      "answer": "10歳以上で8時間のペースに慣れているお子様には向いています。ソプチコジの一部遊歩道はベビーカーでも通れますが、城山日出峰の階段やその他の地形では非推奨です。"
    },
    {
      "id": "order",
      "question": "当日に見どころの順序が変わることはありますか？",
      "answer": "天候や混雑状況によって順序が調整される場合があります。ガイドが最良の体験のために現地判断を行います。"
    },
    {
      "id": "lunch",
      "question": "昼食は料金に含まれていますか？",
      "answer": "いいえ — 昼食は各自ご負担です（≈₩15,000）。ガイドが地元の東済州レストランをご案内します。"
    },
    {
      "id": "why-stone-park",
      "question": "なぜツアーは済州石文化公園から始まるのですか？",
      "answer": "済州石文化公園は済州の石文化・火山地形・（済州創世神話）という文脈をご案内します。この背景を最初に理解することで、その後の城山日出峰や溶岩洞窟の体験がより深まります。"
    },
    {
      "id": "why-seopjikoji",
      "question": "ソプチコジが午前に配置されている理由は何ですか？",
      "answer": "午前中の涼しい時間帯に海岸遊歩道を歩くのが最も快適なためです。また、午後の混雑が始まる前に到着できます。"
    },
    {
      "id": "why-lunch",
      "question": "昼食がそのタイミングに設定されている理由は？",
      "answer": "ソプチコジと城山日出峰の間の自然な中間地点に位置し、城山日出峰到着前に体力を回復するための理想的な休憩タイムです。"
    },
    {
      "id": "later-structure",
      "question": "後半のルートはなぜこのような構成なのですか？",
      "answer": "城山日出峰（最も体力を使う見どころ）を昼食直後に配置することで、エネルギーが充填された状態で挑めます。その後、比較的楽な密川洞窟と城邑民俗村で一日を穏やかに締めくくります。"
    }
  ],
  "guestReviews": [
    {
      "id": 1,
      "author": "Sarah M.",
      "avatar": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80",

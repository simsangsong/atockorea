    "reviews_attribution": "Reseñas verificadas por AtoC Korea. 4.8/5 average across 127 verified bookings.",
    "unesco_fit_note": "unesco_fit=5: two ユネスコ Natural Heritage sites on route — Manjanggul Cave (lava tube system, inscribed 2007) and Seongsan Ilchulbong (Sunrise Peak, inscribed 2007). Note: Manjanggul currently subject to seasonal closure; alternate cave (Micheon) used when closed.",
    "competing_products": [
      "jeju-eastern-unesco-spots-day-tour",
      "jeju-grand-highlights-loop",
      "jeju-southern-top-unesco-spots-tour"
    ],
    "audit_summary": "East Jeju signature nature loop covering 600 years of layered Korean heritage: mythological origin (Seolmundae Halmang at Jeju Stone Park), Joseon yeondae beacon (Seopjikoji Hyeopja), Pulitzer-laureate contemporary architecture (Tadao Ando), Triple ユネスコ tuff cone (Seongsan Ilchulbong), Manjanggul-system lava tube (Ilchulland Micheon Cave), and 1423-founded living walled town (Seongeup Folk Village). Mythology + architecture-anchored counterpart to the eastern-ユネスコ-spots sister tour, which emphasizes Hamdeok beach + Haenyeo Museum ユネスコ Intangible heritage.",
    "score_rationale": {
      "high_scores": {
        "k_drama_filming_fit=0.95": "4 separate K-drama filming sites in one day (Dae Jang Geum, All In, My Girl, Running Man)",
        "tadao_ando_architecture_fit=1.0": "Pulitzer-laureate concrete-minimalism — only Jeju tour with Ando architecture",
        "mythology_fit=1.0": "Seolmundae Halmang creation legend front-loads the day's narrative arc",
        "joseon_walled_town_fit=1.0": "Seongeup = 1423 founding, ~500 years administrative function until 1914",
        "varied_terrain_fit=1.0": "Outdoor museum + cape + tuff cone + lava cave + walled village — rare textural variety",
        "indoor_fallback_anchor_count=3": "Stone Park halls + Ilchulland cave + Seongeup hanok all weather-flexible"
      },
      "low_scores": {
        "private_tour_fit=0.05": "Format is small-group fixed itinerary only",
        "west_jeju_fit=0.05": "Loop deliberately east-anchored",
        "wheelchair_accessible_anchor_fit=0.55": "Seongsan ascent blocks pure-wheelchair full coverage"
      }
    },
    "differentiation_vs_eastern_unesco_sister": "Same Seongsan + Seongeup + Ilchulland anchors, but **mythology + architecture emphasis** (Jeju Stone Park Seolmundae + Tadao Ando Seopjikoji) vs. sister's **ユネスコ Intangible emphasis** (Hamdeok WWII tunnels + Haenyeo Museum 2016 inscription). Both routes appropriate for different guest temperaments — pair complementarily for guests with 2 days.",
    "seasonal_window": {
      "best_months": [

  "staticQuestions": [
    {
      "id": "first-time",
      "question": "제주 첫 방문에 이 코스가 적합한가요?",
      "answer": "네, 제주의 돌 문화, 화산 지형, 동부 해안, 전통 민속마을을 하루에 균형 있게 볼 수 있도록 구성된 코스입니다."
    },
    {
      "id": "walking",
      "question": "일정이 체력적으로 힘들지 않나요?",
      "answer": "보통 수준입니다. 가장 체력이 필요한 구간은 성산일출봉 분화구 등반(선택)이며, 등반을 하지 않더라도 해안 둘레길에서 충분한 전망을 둘러볼 수 있습니다."
    },
    {
      "id": "rain",
      "question": "비가 와도 투어가 진행되나요?",
      "answer": "네, 진행됩니다. 미끄럽거나 바람이 강한 경우 해안 노출 구간에서 안전에 주의하며 진행하며, 일출랜드 실내 구간이 대안이 됩니다."
    },
    {
      "id": "parents",
      "question": "부모님과 함께 참여할 수 있나요?",
      "answer": "보통 수준의 도보와 일부 계단이 있어, 이를 소화할 수 있는 가족 단위 방문에 적합합니다."
    },
    {
      "id": "children",
      "question": "어린이와 함께할 수 있나요?",
      "answer": "만 8세 이상으로 보통 수준 도보가 가능한 어린이에게 적합합니다."
    },
    {
      "id": "order",
      "question": "당일 경유지 순서가 바뀔 수 있나요?",
      "answer": "바람, 교통, 인파에 따라 해안 구간의 방문 순서가 조정될 수 있습니다. 전체 코스는 그대로 진행됩니다."
    },
    {
      "id": "lunch",
      "question": "점심 식사가 포함되어 있나요?",
      "answer": "상품 구성에 따라 다를 수 있습니다. 점심 시간은 항상 제공되며, 식사비 포함 여부는 예약 시 확인하세요."
    },
    {
      "id": "why-stone-park",
      "question": "제주돌문화공원으로 시작하는 이유는 무엇인가요?",
      "answer": "제주의 돌과 화산 문화를 먼저 이해하면, 이후 성산일출봉과 미천굴이 단순 명소가 아닌 지질 이야기의 일부로 와닿기 때문입니다."
    },
    {
      "id": "why-seopjikoji",
      "question": "섭지코지가 오전에 배치된 이유는 무엇인가요?",
      "answer": "오전에 해안 풍경을 먼저 경험하면, 성산일출봉 방문이 오후 하이라이트로 더 강한 인상을 줄 수 있기 때문입니다."
    },
    {
      "id": "why-lunch",
      "question": "점심이 그 시간에 배치된 이유는 무엇인가요?",
      "answer": "성산 구간 전 점심으로 체력을 보충하면, 오후 핵심 명소를 더 여유 있게 둘러볼 수 있습니다."
    },
    {
      "id": "later-structure",
      "question": "오후 일정이 이렇게 구성된 이유는 무엇인가요?",
      "answer": "성산일출봉 등반 후 일출랜드로 일정 속도를 낮추고, 성읍민속마을로 문화적인 마무리를 하는 구성입니다. 긴 이동 없이 자연스럽게 하루를 마무리할 수 있습니다."
    }
  ],
  "guestReviews": [
    {
      "id": 1,
      "author": "Sarah M.",
      "avatar": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80",
      "location": "Singapore",
      "date": "2024년 3월",
      "rating": 5,
      "title": "동제주 투어의 페이싱이 정말 편안했어요",
      "text": "루트 순서가 매우 합리적이었어요. 돌문화공원으로 시작한 것이 이후 모든 것에 실질적인 배경을 제공했고, 가이드가 지질학적 이야기를 연결해줘서 성산일출봉과 일출랜드가 단순한 개별 코스가 아닌 하나의 큰 이야기의 일부처럼 느껴졌어요. 점심 타이밍도 완벽해서 오후 성산에서도 충분한 에너지가 남아 있었어요.",
      "helpful": 24,
      "verified": true,
      "tripType": "커플",
      "photos": [
        "https://images.unsplash.com/photo-1596402184320-417e7178b2cd?w=400&q=80",
        "https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=400&q=80"
      ]
    },
    {
      "id": 2,
      "author": "James K.",
      "avatar": "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80",
      "location": "Hong Kong",
      "date": "2024년 3월",
      "rating": 5,
      "title": "하루에 동제주를 보기에 훌륭한 가성비",
      "text": "한국에서 당일 투어를 몇 번 참여해봤는데, 이번에 돋보였던 것은 루트가 얼마나 신중하게 순서가 짜여 있는지였어요. 가이드는 언제 속도를 늦추고 언제 하루를 앞으로 나아가야 하는지 명확히 알고 있었어요. 민속마을로 마무리하는 것도 영리한 선택이었어요. 많은 자연 경치 후에 문화적 마무리가 하루에 다른 종류의 깊이를 더해줬어요.",
      "helpful": 18,
      "verified": true,
      "tripType": "가족",
      "photos": []
    },
    {
      "id": 3,
      "author": "Yuki T.",
      "avatar": "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80",
      "location": "Tokyo",
      "date": "February 2024",
      "rating": 4,
      "title": "훌륭한 루트, 하지만 성산에서 좀 더 시간을 보내고 싶었어요",
      "text": "전반적으로 매우 훌륭한 하루였어요. 돌문화공원이 기대보다 훨씬 흥미로웠고, 일출랜드는 성산 다음의 완벽한 후속 코스였어요. 4점을 준 것은 개인적으로 성산에서 15분 더 있고 싶었기 때문이지만, 하루 전일 루트의 시간 제약도 이해해요.",
      "helpful": 12,
      "verified": true,
      "tripType": "혼자",
      "photos": [
        "https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=400&q=80"

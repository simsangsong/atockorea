    {
      "id": "faq",
      "section_html_id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "q-tuesday",
            "question": "如果我的靠港日恰好是周二怎么办？",
            "answer": "景福宫周二闭馆。周二靠港的行程改为昌德宫＋秘苑，后者是UNESCO世界文化遗产（唯一获得此指定的朝鲜宫殿），秘苑需另付₩5,000门票，并跟随固定时段讲解。其他行程安排不变。"
          },
          {
            "id": "q-hanbok",
            "question": "韩服可以在哪里租借？",
            "answer": "大多数韩服租借店集中在景福宫光化门城门附近及安国站周边——即宫殿区，并非如部分导游所说的北村内部。标准租借约₩15,000至₩25,000（4小时租借）；穿着韩服可免费进入景福宫。请在预订时告知若有韩服计划，以便安排时间。"
          },
          {
            "id": "q-cruise-customize",
            "question": "可以依我的邮轮时刻自订行程吗？",
            "answer": "有限度弹性——本行程是固定路线共乘产品。接送和下车时间会自动依您的邮轮靠港出境及出港时间调整。导游可在各景点微调停留时间，但无法替换景点。"
          },
          {
            "id": "q-cruise-port-buffer",
            "question": "最迟何时返回邮轮码头？",
            "answer": "在您的出港时间前至少60分钟抵达码头。返程75分钟车程是全日最长的单一转场；高峰时段及雨天可能拉长至90分钟，因此60分钟预留时间是安全的最低标准。"
          },
          {
            "id": "q-changing-of-the-guard",
            "question": "能看到王宫守卫换岗仪式吗？",
            "answer": "要看时机——取决于您的邮轮靠港时间。仪式在景福宫光化门外每日10:00及14:00举行（周二及恶劣天气除外）。若您09:00下船，通常可以赶上10:00场次；若下船较晚，则需配合14:00场次或略过。"
          },
          {
            "id": "q-gwangjang-must-eat",
            "question": "在广藏市场应该吃什么？",
            "answer": "三大招牌：（绿豆煎饼，市场最著名菜色，以猪油煎制，约₩5,000，很饱足）；（「毒品饭卷」，一口迷您芝麻紫菜饭卷，附芥末酱，约₩3,000）；（辣血肠加杂碎拼盘，约₩5,000，冬季最佳）。全部加起来仍在₩15,000预算内。"
          },
          {
            "id": "q-bukchon-residents",
            "question": "北村是旅游景点还是真实住宅区？",
            "answer": "是真实住宅区。北村约600栋韩屋中的大多数是私人住宅；仅部分改建为茶房、工艺坊或小型博物馆。居民要求22:00至10:00的静音时段，但首尔市也在白天设立了静音引导。请保持安静，避免在私人门口拍照。"
          },
          {
            "id": "q-vegetarian",
            "question": "广藏市场有素食选项吗？",
            "answer": "有。（绿豆煎饼）天然素食；（凉拌辣酱面，无肉）可靠；炒年糕（素食版）在多个摊位有售。导游可协助辨识及翻译素食选项。"
          },
          {
            "id": "first-time",
            "question": "这是初次造访首尔的邮轮旅客的好选择吗？",
            "answer": "对邮轮旅客而言是最强推荐——四个核心景点（王宫、韩屋、市场、文化街）是首尔最常被问到的景点，路线依邮轮时刻设计，确保准时返船。"
          },
          {
            "id": "walking",
            "question": "步行距离大约多少？",
            "answer": "全程约4公里。景福宫平坦的大型庭院是最长的单一步行段；北村有轻微坡道；广藏市场和仁寺洞均为平坦路面。建议穿着舒适的封口鞋。"
          },
          {
            "id": "family",
            "question": "带小孩的家庭适合吗？",
            "answer": "适合学龄儿童（约8岁以上）。孩子喜欢换岗仪式（如时间配合）及广藏市场的街头美食体验。北村安静的住宅巷道对年幼孩子的吸引力有限。如携带幼儿，请在预订时告知。"
          },
          {
            "id": "seniors",
            "question": "年长旅客能否舒适地参加？",
            "answer": "可以。节奏中等；最长的单段步行是景福宫庭院（平坦，设有休息座椅）。北村坡道有一定体力需求，但大多数观景点走轻松路线即可到达。无障碍旅客注意：景福宫可从兴礼门轮椅通行；北村观景点不适合轮椅。"
          },
          {
            "id": "children",
            "question": "建议最低年龄是多少？",
            "answer": "建议约8岁以上——能应对上述步行量及全日邮轮节奏的孩子。若携带年幼孩子，请在预订时告知，以便导游相应调整节奏。"
          },
          {
            "id": "rain",
            "question": "若当天大雨怎么办？",
            "answer": "小雨照常出发——大多数景点有室内或有盖选项（宫殿展厅、广藏市场、仁寺洞拱廊）。大雨时：景福宫及北村户外时间可能缩短，相应延长市场及仁寺洞室内停留。台风级天气提供全额退款。"
          }
        ]
      }

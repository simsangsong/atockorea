  ],
  "practicalWeatherStatic": {
    "summary": "경주의 3월 말~4월 초 날씨는 약 5~18°C로 변동이 큰 편입니다. 봄꽃은 바람과 비의 영향을 많이 받아 강한 비가 오면 하루 만에도 꽃잎이 떨어질 수 있으므로, 출발 전 개화 상황과 날씨를 함께 확인합니다.",
    "advice": "아침에는 가벼운 재킷이 필요하고 낮에는 벗을 수 있도록 여러 겹으로 입는 것이 좋습니다. 4월에는 소나기가 올 수 있으니 얇은 우비를 준비해 주세요. 편한 신발, 충전된 카메라, 보조배터리도 권장합니다."
  },
  "seasonalVariations": [
    {
      "season": "봄 (3월 28일~4월 10일) — 운영 시즌",
      "summary": "투어가 운영되는 유일한 기간. 3월 말 = 시내 초기 개화(보문호, 대릉원). 4월 초 = 전지역 절정.",
      "swaps": "매일 루트는 당일 아침 개화 보고 기반으로 벚꽃 풀에서 2~3개 코스 선택."
    },
    {
      "season": "여름 / 가을 / 겨울 — 투어 운영 없음",
      "summary": "이것은 시즌 한정 봄 상품입니다. 다른 계절 경주 방문은 연중 상품을 참조하세요.",
      "swaps": "불국사, 경주 국립박물관, 교촌, 월정교 연중 방문은 연중 상품 참조."
    }
  ],
  "bookingTrustItems": [
    {
      "icon": "shield-check",
      "title": "봄 시즌 전문 여행사",
      "detail": "KMA 개화 예보가 변경되어 약속된 경험을 제공할 수 없는 경우, 전액 환불 또는 무료 일정 변경.",
      "body": "3/28~4/10 봄 벚꽃 한정 투어 — 벚꽃 개화 정보 실시간 안내."
    },
    {
      "icon": "calendar-check",
      "title": "코스 전문",
      "detail": "매일 아침 투어 리더가 출발 전 현재 절정인 2~3개 코스를 확인합니다.",
      "body": "보문호 → 첨성대·대릉원 → 불국사 순서로 경주 봄의 이야기가 자연스럽게 이어집니다."
    },
    {
      "icon": "user-check",
      "title": "그룹 규모 관리",
      "detail": "모든 투어 리더는 자격증을 보유하고 영어를 구사합니다. 다수가 이중 언어(한국어/영어/중국어).",
      "body": "소그룹 밴(최대 10인)으로 여유 있게 이동합니다."
    }
  ],
  "bookingSupportSteps": [
    {
      "step": 1,
      "title": "즉시 확인",
      "detail": "3월 28일~4월 10일 창 내 날짜 선택 — 오늘 결제 불필요, 지금 예약하고 나중에 결제.",
      "description": "픽업 역·시각 포함 즉시 예약 확인서 발송."
    },
    {
      "step": 2,
      "title": "12시간 전 알림",
      "detail": "부산역 (KTX) 08:00, 서면 08:15, 해운대 08:30 중 선택.",
      "description": "벚꽃 당일 개화 상태 사전 안내."
    },
    {
      "step": 3,
      "title": "최종 픽업 안내",
      "detail": "3월 중순까지 KMA 예보로 운영 기간 확인; 예약 날짜가 개화 기간 밖이면 예약 변경 옵션 제공.",
      "description": "출발 전날 저녁 최종 픽업 시각 확인."
    },
    {
      "step": 4,
      "title": "당일 코스 안내",
      "detail": "투어 리더가 당일 아침 실시간 개화 보고를 기반으로 구체적인 2~3개 코스를 확인합니다.",
      "description": "날씨 및 개화 상태 아침 메시지 전달."
    },
    {
      "step": 5,
      "title": "경유지별 심층 안내",
      "detail": "투어 리더가 예정된 픽업 시간에 AtoC Korea 표지판을 들고 승강장에서 대기합니다.",
      "description": "경주 유네스코 역사지구 배경, 신라 천년 역사 가이드 설명."
    },
    {
      "step": 6,
      "title": "투어 후 지원",
      "detail": "동일 역 하차 약 16:30; 총 투어 약 8.5시간.",
      "description": "투어 후 피드백 요청 전송."
    }
  ],
  "staticQuestions": [
    {
      "question": "투어 운행 기간은 언제인가요? 벚꽃 시기를 놓치면 어떻게 되나요?",
      "answer": "매년 약 3월 28일~4월 10일 운행. 정확한 날짜는 기상청 벚꽃 예보를 기준으로 매년 3월 중순에 확정됩니다."
    },
    {
      "question": "일정이 고정되어 있나요?",
      "answer": "기본 코스는 보문호 → 첨성대+대릉원 → 불국사입니다. 당일 인파·교통에 따라 순서가 소폭 조정될 수 있습니다."
    },
    {
      "question": "어르신·유모차 접근이 가능한가요?",
      "answer": "보문호와 대릉원은 유모차·휠체어 친화적(평탄한 포장 산책로). 불국사는 고르지 않은 석재와 완만한 오르막이 있습니다."
    },
    {
      "question": "점심 비용과 입장료는 어떻게 되나요?",
      "answer": "점심 식사비 별도(약 ₩10,000~20,000). 입장료: 불국사 무료(2023년 5월~), 첨성대·대릉원은 소액 입장료 또는 무료(연도에 따라 변동 — 예약 시 확인)."
    }
  ],

  "itinerary_variants": [],
  "_publication": {
    "schema_version": "v4_canonical",
    "last_modified": "2026-04-29",
    "version_history": [
      "v11",
      "v12",
      "v13",
      "v14",
      "v15",
      "v15.2",
      "v17_batch7"
    ],
    "fix_passes": {
      "v12": "P0+P1 — pickup_dropoff Schema A unification, routeFlowStops type-based, competing_products → internal slugs, anchor_poi_keys aligned",
      "v13": "P1.5 — pickup_dropoff Schema A.2 → A.1; practicalAccordionItems / routePhases / seasonalVariations unified to V4 canonical (no Tailwind in data)",
      "v14": "P2 — _publication uniform; duration formatting standardized; glanceItems Duration added where missing",
      "v15": "P3 round 1 — SEO trim. seo.pageTitle rewritten to ≤65 chars (was 14/25 over 70); seo.metaDescription rewritten to ≤168 chars (was 25/25 over 170). primaryKeywords and ogImage unchanged. Hero/OG images, POI verification, review imports, and routePhases enrichment deferred to later P3 rounds.",
      "v15.2_charter_consolidation": "Removed \"jeju-popular-sightseeing-private-car-charter-tour\" from competing_products per Jason's one-charter-per-region rule (jeju-island-private-car-charter-tour remains as canonical Jeju charter).",
      "v17_schema_unification": {
        "date": "2026-04-28",
        "description": "Phase 1: Converted product profile scores from 1-5 int scale to 0-1 float scale to match the 3 Step 3 new tours. Mapping 1→0.20, 2→0.40, 3→0.60, 4→0.80, 5→1.00. Mechanical conversion preserves ordinal information; verified-fact recalibration happens in subsequent enhancement batches.",
        "fields_converted": 43,
        "fields_skipped": 0,
        "fields_already_float": 0
      },
      "v17_batch7_enhancement": {
        "date": "2026-04-29",
        "description": "Batch 7 deep enhancement — private charter pair (Jeju + Seoul). Both tours have 4 route options as itineraryStops (East/West/South/Custom for Jeju; Gapyeong/DMZ-Paju/Everland-Folk/Custom for Seoul). Each route option enhanced with 1,000+ char descriptions weaving verified facts about constituent POIs into a coherent route narrative. product profile recalibrated to verified-fact 0-1 float scores using cross-route weighted averaging. private_tour_fit, customizable_route_fit, flexibility_fit set from None to 1.0. 9 new POIs added to KB (v1.9 → v1.10): udo_island, manjanggul_lava_tube, sanbangsan_mountain, sangumburi_crater, yakcheonsa_temple, garden_of_morning_calm, petite_france, everland, korean_folk_village_yongin. DMZ POIs and Nami Island deferred to Batch 8.",
        "_score_audit": {
          "_methodology": "0-1 float scale per Phase 1 standard. Both tours are private 9-10hr charters with 4 route options (East/West/South/Custom for Jeju; Gapyeong/DMZ-Paju/Everland-Folk/Custom for Seoul). Scores are weighted averages across the recommended routes, with extreme-outlier dimensions weighted toward the realistic middle (e.g. UNESCO score reflects average across routes — Route 1 maxes UNESCO, but weighted average ~0.65). Charter-format dimensions (private_tour_fit, customizable_route_fit, flexibility_fit) are set to 1.0 by definition. Walking_level and indoor_ratio are time-weighted averages across the typical day.",
          "deltas_applied": {
            "private_tour_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Both tours are per-vehicle private charters by definition. Was previously None (unset)."
            },
            "customizable_route_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Three recommended routes plus a fully custom option. Both tours fully customizable. Was previously None."
            },
            "flexibility_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Driver-guide adapts pacing, order, lunch, optional add-ons (Udo ferry, Smart Queue). Was previously None."
            },
            "small_group_fit": {
              "old": 0.2,
              "new": 0.15,
              "reasoning": "Verified — these are PRIVATE charters not small-group. 0.15 reflects that a 1-vehicle-of-9 booking still functions as a small private group, but the product type is private not small_group."
            },
            "bus_fit": {
              "old": 0.2,
              "new": 0.05,
              "reasoning": "Verified — private charter = sedan/SUV/van, never bus. 0.05 reflects near-zero bus fit (only the very largest groups of 10+ would step up to a coach format)."
            },
            "unesco_fit": {
              "old": 1.0,
              "new": 0.65,
              "reasoning": "VERIFIED weighted average across routes. Route 1 (East): max UNESCO — Seongsan Ilchulbong is triple-UNESCO + Manjanggul UNESCO 2007. Route 2 (West): minimal UNESCO content. Route 3 (South): partial UNESCO — Jusangjeolli is Global Geopark, Sanbangsan is Geopark. Weighted across routes = ~0.65, significantly lower than the previous 1.0 which assumed Route 1 always selected. Custom Route can max UNESCO if the traveler picks specifically — but the average traveler will not."
            },
            "scenic_level": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "VERIFIED — all 3 named routes deliver catalog-leading scenic content (volcanic crater, beach, basalt cliff, waterfall, tea field, lava dome). 0.95 calibrated, only marginally below max (saving 1.0 for tours that deliver multiple flag邮轮 scenic types in a single 9-hour window — which only Route 1 of 3 does)."
            },
            "first_time_fit": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "VERIFIED — strongest first-time-Jeju option because Route 1 alone covers the bucket-list UNESCO sites. 0.95 reflects that the WEST route is less first-time-iconic than East, so an averaged score is just below absolute max."
            },
            "iconic_landmark_fit": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "VERIFIED — Seongsan Ilchulbong is Jeju's single most iconic landmark and is included on Route 1 + Custom. Slight markdown to 0.95 because Routes 2 (West) and 3 (South) trade iconic landmark count for café/temple density."
            },
            "walking_level": {
              "old": 0.6,
              "new": 0.5,
              "reasoning": "VERIFIED — weighted across routes. Route 1: Seongsan summit climb is the bottleneck (~0.7). Route 2: low (~0.3 — beach, park, café). Route 3: Sanbangsan stairs to cave temple (~0.55). Average ~0.5, slightly below previous 0.6."
            },
            "indoor_ratio": {
              "old": 0.3,
              "new": 0.2,
              "reasoning": "VERIFIED — weighted across routes (Fix 1 time-weighted methodology). Route 1: low indoor (~0.15 — Manjanggul is the only major indoor stop, and is currently closed). Route 2: moderate (~0.25 — Hallim Park caves + O'sulloc museum interiors). Route 3: moderate (~0.30 — Yakcheonsa main hall, Olle Market arcade, Sanbanggulsa cave). Average ~0.20, lower than previous 0.30. Note: with Manjanggul closed (until verified reopening), the actual indoor exposure on Route 1 is even lower."
            },
            "weather_sensitivity": {
              "old": 0.4,
              "new": 0.5,
              "reasoning": "VERIFIED — moderate weather sensitivity. Route 1 (East UNESCO) is heavily outdoor and weather-vulnerable. Route 3 (South temples + market) has the strongest indoor fallback. The PRIVATE-charter format itself reduces weather impact (driver-guide can shift to indoor stops on bad-weather days), but the recommended routes are still mostly outdoor. 0.50 calibrated up from 0.40 — previous 0.40 over-credited the charter format flexibility."
            },
            "shopping_fit": {
              "old": 0.8,
              "new": 0.55,
              "reasoning": "VERIFIED — only Route 3 has substantial shopping (Olle Maeil Market). Routes 1, 2 have minimal shopping (Aewol cafés, beach souvenir kiosks). Custom Route can max shopping if specifically requested. Weighted ~0.55, materially lower than the previous 0.80 which appeared inflated."
            },
            "food_fit": {
              "old": 0.6,
              "new": 0.7,
              "reasoning": "VERIFIED — Jeju's food density is high across all routes (haenyeo seafood, Hallabong tangerines, black pork, Olle Market). Route 1 has the strongest meal hubs (Seongsan harbor); Route 3 has Olle Market. 0.70 calibrated up from previous 0.60."
            },
            "premium_fit": {
              "old": 1.0,
              "new": 1.0,
              "reasoning": "Verified — private vehicle + flexible itinerary + driver-guide = top of premium scale. Maintained at 1.0."
            },
            "value_for_money_fit": {
              "old": 0.6,
              "new": 0.55,
              "reasoning": "Verified — per-vehicle pricing is excellent value for groups of 4-9 but expensive for solo travelers. Slight markdown to 0.55 reflects the per-person break-even calculation: vs. small-group bus tours at ~70,000 KRW per person, the charter only beats it for groups of 5+."
            },
            "storytelling_fit": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified — driver-guide narrates throughout, and the routes carry strong narrative arcs (UNESCO geology, K-drama, Joseon folk culture, tea-merchant heritage). 0.85 reflects that narrative depth varies by driver-guide assigned and by route chosen — was previously 1.0 which assumed uniformly maximal storytelling, which is not realistic."
            }
          }
        }
      }
    }
  }

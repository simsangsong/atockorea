    {
      "id": "itinerary",
      "section_html_id": "itinerary",
      "component": "TourTimelineSection",
      "props": {
        "itineraryStops": [
          {
            "number": 1,
            "name": "東部路線：UNESCO與韓劇海岸",
            "category": "城山、牛島、萬丈窟、涉地可支",
            "description": "**濟州島東部路線**是私人包車行程的核心路線選項，以**UNESCO世界遺產城山日出峰**和著名的**韓劇拍攝地涉地可支岬角**為雙核心。東部路線全日涵蓋：城山日出峰（UNESCO三重認定）登頂或峰下海女表演；涉地可支岬角（安藤忠雄建築 + 春季油菜花 + 夏季繡球花）；城邑民俗村（朝鮮時代保存城鎮）；以及沿東部海岸的咖啡廳停靠。此路線是4條私人包車路線中**攝影景點豐富度最高**的路線，適合首次造訪濟州且希望在一日內覽遍東部精華的旅客。行程依您的節奏靈活調整，司導會根據天氣和人潮推薦最佳停靠時機。",
            "highlights": [
              "城山日出峰（UNESCO三重認定）— 登頂或峰下15:00海女表演",
              "涉地可支岬角（安藤忠雄建築 + 韓劇拍攝地）",
              "城邑民俗村（朝鮮時代保存城鎮，UNESCO韓國山寺）",
              "東部海岸咖啡廳停靠",
              "**攝影景點豐富度最高的私人包車路線**",
              "春季4月：油菜花；夏季6月：繡球花；全年：城山日出峰",
              "行程依您的節奏靈活調整",
              "9小時私人包車服務；司導負責所有安排",
              "適合首次造訪濟州且希望覽遍東部精華的旅客"
            ],
            "timeUsed": [
              "濟州市飯店接送+至東海岸約70–90分鐘",
              "主要景點2–3處（導遊司機根據當日現場情況調整順序）",
              "自選午餐（通常在城山港附近海鮮餐廳）",
              "可選牛島渡輪體驗（每人另付約8,900韓元船票；車輛停放於城山）"
            ],
            "whyOnRoute": "**最適合初次造訪濟州**、希望最大化代表性景點辨識度的路線。城山日出峰提供島上最具代表性的UNESCO日出峰攝影，萬丈窟（開放時）讓路線擁有其他濟州路線無可取代的地下UNESCO體驗，而涉地可支 + 城邑民俗村則補充了韓劇和民俗文化層次。四條路線中**UNESCO豐富度最高**的選項。",
            "visitBasics": {
              "hours": "大多數景點09:00–18:00；萬丈窟（開放時）每月第一個週三休館",
              "closed": "城山：每月第一個週一。萬丈窟：目前關閉",
              "admission": "各景點現場自付——城山₩5,000，萬丈窟₩4,000（開放時）",
              "walking": "中等至較難——城山火山口登頂最為費力"
            },
            "convenience": {
              "restroom": "所有主要景點設有廁所",
              "parking": "導遊司機處理"
            },
            "smartNotes": {
              "photo": "晴天清晨城山日出峰頂部是此路線最佳拍攝時機。",
              "facilities": "城山港和鹹德海灘是最強的餐飲據點。",
              "tip": "城山頂部登頂對老年或行動不便遊客為關鍵節點——請預留充足時間。"
            },

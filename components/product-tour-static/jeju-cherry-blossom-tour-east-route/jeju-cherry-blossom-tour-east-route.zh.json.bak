      "v17_schema_unification": {
        "date": "2026-04-28",
        "description": "Phase 1: Converted product profile scores from 1-5 int scale to 0-1 float scale to match the 3 Step 3 new tours. Mapping 1→0.20, 2→0.40, 3→0.60, 4→0.80, 5→1.00. Mechanical conversion preserves ordinal information; verified-fact recalibration happens in subsequent enhancement batches.",
        "fields_converted": 43,
        "fields_skipped": 0,
        "fields_already_float": 0
      },
      "v17_batch4_enhancement": {
        "date": "2026-04-29",
        "description": "Batch 4 deep enhancement — descriptions raised to 700-1300+ chars; KB-backed metadata on all attraction stops; product profile recalibrated with verified-fact 0-1 float scores. Time-weighted indoor_ratio computation per Fix 1 methodology.",
        "_score_audit": {
          "_methodology": "0-1 float scale. Indoor ratio computed time-weighted using KB indoor_ratio_at_stop methodology. Note this tour SPLITS the Ilchul Land visit into two stops — the cave (high indoor ratio at 100%) and the gardens (low indoor ratio at 20%) — so the average works out to ~30% across the combined Ilchul Land time, consistent with KB.",
          "deltas_applied": {
            "unesco_fit": {
              "old": 0.6,
              "new": 0.5,
              "reasoning": "Verified: Seongsan is a photo stop (UNESCO World Heritage). Other stops are non-UNESCO (Jeonnong/Noksan are city/country roads, Ilchul Land is private park). 1/6 stops = 0.50 calibrated."
            },
            "walking_level": {
              "old": 0.4,
              "new": 0.45,
              "reasoning": "Verified: Jeonnong-ro 1.2 km flat (easy), Noksan-ro is drive-and-stop (minimal walking), Micheon Cave 365 m flat, Ilchul Land 1 km flat, Seongsan photo-stop format excludes the climb. Total walking ~3 km flat. 0.45 calibrated."
            },
            "scenic_level": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "Verified — exceptional spring scenery: city cherry tunnel + 10 km cherry+canola+turbine country road + lava tube colored lighting + UNESCO peak. 0.95 — high diversity in spring window."
            },
            "photo_level": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "Verified: 5 distinct hero shots — Jeonnong cherry tunnel, Noksan cherry+canola+windmill, 7-color cave, Seongsan crater. Among most photogenic Jeju tours but season-dependent. 0.95."
            },
            "iconic_landmark_fit": {
              "old": 0.8,
              "new": 0.75,
              "reasoning": "Verified: Seongsan universally iconic, Noksan is regionally iconic ('100 Most Beautiful Roads in Korea'), Jeonnong is festival-iconic, Ilchul Land + Micheon are secondary. 0.75 calibrated."
            },
            "indoor_ratio": {
              "old": 0.4,
              "new": 0.2,
              "reasoning": "MAJOR CORRECTION using time-weighted method (Fix 1 methodology): substantive stops are predominantly outdoor cherry-blossom corridors. Time-weighted: 42 indoor / 270 substantive min = 0.16. With lunch: 0.27. Catalog value 0.20 represents both. Mechanical Phase 1 conversion 0.4 was overstated."
            },
            "weather_sensitivity": {
              "old": 1.0,
              "new": 0.9,
              "reasoning": "VERIFIED — extremely weather-sensitive: cherry blossoms are season-AND-weather dependent (rain destroys blossoms within hours; wind blows down petals); 80%+ outdoor stops. Highest weather-sensitivity in catalog after spring-only flower tours."
            },
            "rain_fit": {
              "old": 0.6,
              "new": 0.3,
              "reasoning": "DOWNGRADED — cherry blossoms are particularly rain-vulnerable (blossoms fall within hours of heavy rain). Only Micheon Cave + Ilchul Land partial indoor provide refuge. 0.30 calibrated for honest rain-fit."
            },
            "first_time_fit": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified: excellent SPRING first-Jeju but season-locked to ~10 days/year. Outside cherry season this tour wouldn't run. 0.85 calibrated for season-specific value."
            },
            "value_for_money_fit": {
              "old": 0.6,
              "new": 0.75,
              "reasoning": "Verified fees: Jeonnong free + Noksan free + Ilchul ₩12,000 + Seongsan ₩2,000 = ~₩14,000 + scenic country drive value. 0.75 — reasonable spring value."
            },
            "young_kids_fit": {
              "old": 0.8,
              "new": 0.65,
              "reasoning": "Verified: Jeonnong city walk (good for kids), Noksan drive (kids may get bored), Ilchul Land black pigs + leveled cave (kid-friendly), Seongsan photo stop (no climb required). 0.65 — generally kid-friendly with one drive-heavy section."
            },
            "senior_fit": {
              "old": 0.6,
              "new": 0.65,
              "reasoning": "UPGRADED — flat city walks + drive-and-stop country road + leveled cave + photo-stop Seongsan = highly senior-accessible. Mechanical 0.6 understated; verified 0.65."
            },
            "stroller_fit": {
              "old": 0.6,
              "new": 0.7,
              "reasoning": "UPGRADED — Jeonnong flat road, Noksan drive-only, Micheon Cave leveled, Ilchul Land flat paths, Seongsan base-only photo stop. 5/5 stroller-friendly = 0.70."
            },
            "mobility_friendly_fit": {
              "old": 0.4,
              "new": 0.65,
              "reasoning": "UPGRADED — same logic: tour is predominantly drive-to-walk-and-back format with leveled paths and photo-stop Seongsan. 0.65 verified."
            },

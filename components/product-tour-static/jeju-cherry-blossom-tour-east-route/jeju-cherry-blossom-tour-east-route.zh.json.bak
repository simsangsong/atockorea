    "source_of_truth_note": "Internal note: product profile checked against current route-selection rules. This product uses one fixed route.",
    "audit_summary": "Spring-only east Jeju cherry+canola route. Strong substitution relation邮轮 with jeju-eastern-unesco-spots-day-tour (off-season fallback). Hard constraint on cherry season dates; weather_sensitivity=0.85 reflects bloom dependency. New POI added in v1.17: ilchulland_themed_gardens (separated from cave, prior version mistakenly used same key).",
    "score_rationale": {
      "high_scores": {
        "scenic_level=5, photo_level=5": "Cherry blossom + canola at Noksan-ro is one of Jeju's peak photo scenes; double bloom layering is unique to this season.",
        "couple_fit=5": "Cherry blossom corridor and garden pacing read strongly couple-romantic.",
        "small_group_fit=5": "Small group format (van) — appropriate for relaxed photo pacing.",
        "weather_sensitivity=5": "Cherry blossoms dependent on bloom window AND weather; rain reduces visual impact sharply."
      },
      "low_scores": {
        "rain_fit=1": "Cherry blossom in heavy rain is sharply less valuable than in dry conditions.",
        "shopping_fit=1": "No shopping POIs.",
        "private_fit=1, bus_fit=1": "Format is small group only.",
        "same_day_flight_fit=2": "8-hour day with 17:30 return makes evening flights tight."
      },
      "calibration_against_eastern_unesco": "Same region, similar duration. Differences: cherry-blossom replaces stone+culture focus; weather_sensitivity raised from 3 to 5; rain_fit dropped from 3 to 1; couple_fit raised from 4 to 5; mobility_friendly_fit equal (3) since no summit climb; shopping_fit equal (1)."
    },

      {
        "title": "行程安排思路",
        "icon": "route",
        "iconBg": "bg-sky-50/80",
        "iconColor": "text-sky-600",
        "items": [
          {
            "label": "一日涵蓋三個時代韓國",
            "detail": "水原華城（18世紀朝鮮）→韓國民俗村（朝鮮時代末期日常生活）→星空圖書館（2024年現代韓國）——三個截然不同的時代景觀，在一日行程中構成完整的韓國文化弧線。"
          },
          {
            "label": "按表演時程規劃路線",
            "detail": "民俗村排在下午（14:00及15:30表演）是關鍵構成——若改為上午，旅客將錯過騎馬武藝和農樂等表演；城牆和行宮排在早晨，在大型韓語導覽團湧入前抵達，確保最佳參觀體驗。"
          },
          {
            "label": "星空圖書館作為全天室內預留時間",
            "detail": "繼三個戶外歷史景點後，星空圖書館提供全程室內的下午收尾——有效預留時間任何午後天氣風險，美食廣場同時解決晚午餐需求，一石二鳥。"
          },
          {
            "label": "全年路線",
            "detail": "與受季節強烈影響的南怡島或雪嶽山行程不同，這條路線適合任何天氣。"
          }
        ]
      },
      {
        "title": "實際步行強度究竟如何",
        "icon": "footprints",
        "iconBg": "bg-emerald-50/80",
        "iconColor": "text-emerald-600",
        "items": [
          {
            "label": "要塞城牆：全天最費力路段",
            "detail": "在長安門和華西門之間行走約1公里，有陡峭路段和城門臺階。必須穿舒適鞋履。"
          },
          {
            "label": "民俗村：約2小時，基本平坦",
            "detail": "園區寬闊但路徑平坦至微坡。計劃約2小時步行；坐著觀看錶演可間歇休息。"
          },
          {
            "label": "行宮和星野：輕鬆",
            "detail": "宮殿內院平坦，有些庭院臺階。星野圖書館全層可乘扶梯/電梯。"
          }
        ]
      },
      {
        "title": "當天氣和季節變化時",
        "icon": "cloud-sun",
        "iconBg": "bg-amber-50/80",
        "iconColor": "text-amber-600",
        "items": [
          {
            "label": "四月初櫻花",
            "detail": "城牆沿線種滿櫻花樹——4月初是最佳拍攝時段。行宮廣場附近有韓服租賃。"
          },
          {
            "label": "七八月夏季高溫",
            "detail": "城牆遮蔭極少。全天轉向民俗村有蔭路徑和室內星野時間。"
          },
          {
            "label": "十二月至二月冬季寒冷",
            "detail": "寒冷天氣城牆步行縮短；民俗村室內表演日程減少。星野自然成為避寒好去處。"
          }
        ]
      }
    ]
  },

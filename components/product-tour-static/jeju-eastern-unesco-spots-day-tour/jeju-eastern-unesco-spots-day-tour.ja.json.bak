    {
      "id": "faq",
      "section_html_id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "q1",
            "question": "海女（ヘニョ）の生きた潜水を見られますか？",
            "answer": "海女博物館では実際の潜水映像をご覧いただけます。海女による生の実演は、隣接する漁港や城山日出峰の麓（通常13:30と15:00、天候によって異なります）で行われることがあります。ツアーのスケジュールは実演を見られる可能性を高めますが、保証はしておりません。"
          },
          {
            "id": "q2",
            "question": "城山日出峰の山頂登頂はスキップできますか？",
            "answer": "はい — 麓の無料の海岸遊歩道からも、階段を使わずに同様の撮影ポイントをお楽しみいただけます。90分の滞在時間はどちらの選択にも対応しています。足腰に不安のある方や、ゆっくりペースをご希望の方には海岸遊歩道がおすすめです。"
          },
          {
            "id": "q3",
            "question": "南部ユネスコツアーとの違いは何ですか？",
            "answer": "同じ催行会社のツアーです。南部ツアーは漢拏山（ハルラサン）トレイル、山茶花の丘、天帝淵の滝、柱状節理（チュサンジョルリ）、雪緑茶博物館を中心としています。こちらの東部ツアーは城山日出峰、海女文化、城邑民俗村を核心としています。2つのツアーは見どころの重複がなく、両日程を合わせることで済州島全体を網羅できます。"
          },
          {
            "id": "q4",
            "question": "滞在中に万丈窟が再開した場合はどうなりますか？",
            "answer": "万丈窟（密川洞窟より有名で長い溶岩トンネル）が再開した場合、催行会社が洞窟見どころを変更する可能性があります。万丈窟は安全修復工事のため現在閉鎖中で、再開時期は未定です。予約時にご確認ください。"
          },
          {
            "id": "q5",
            "question": "昼食は含まれていますか？",
            "answer": "いいえ — 昼食は各自ご負担となります（≈₩15,000）。ガイドが地元の東済州レストランをご案内し、ベジタリアンや食物アレルギーへの対応もサポートします。"
          },
          {
            "id": "q6",
            "question": "なぜ済州空港はゲート3ではなくゲート1なのですか？",
            "answer": "東部ツアーは済州空港ゲート1（1階国内線到着口）をご利用いただきます。空港から東海岸へのルートはゲート1側から出発すると最短だからです。催行者の南部ツアーはゲート3をご利用ください。出発前にご確認ください。"
          },
          {
            "id": "first-time",
            "question": "東済州初訪問者にはおすすめですか？",
            "answer": "はい — この地域で最も個性的な見どころをバランスよく1日で網羅できます。日出峰、海女文化、民俗村、溶岩洞窟という4種類の体験が凝縮されており、初訪問者にとって東済州の全体像をつかむのに最適です。"
          },
          {
            "id": "walking",
            "question": "歩行は大変ですか？",
            "answer": "活動量の多い一日で、歩きごたえのある見どころが複数あります。城山日出峰の山頂登頂（任意）、城邑民俗村の石畳の小道、密川洞窟の階段と凹凸のある通路が含まれます。1日の総歩行距離は約4〜5kmです。動きやすい靴をお履きください。"
          },
          {
            "id": "family",
            "question": "このツアーはファミリーに向いていますか？",
            "answer": "1日中移動できるお子様がいるご家族には向いています。10歳以上のお子様には充実した内容になります。階段や舗装されていない道があるため、ベビーカーは非推奨です。"
          },
          {
            "id": "seniors",
            "question": "高齢の方も参加できますか？",
            "answer": "階段や凸凹の地面に慣れたアクティブなシニアの方に限りおすすめできます。城山日出峰の登頂（≈600段）は任意ですが、城邑民俗村と密川洞窟にも不整地の歩行が含まれます。"
          },
          {
            "id": "children",
            "question": "参加の推奨最低年齢は？",
            "answer": "10歳前後が最適です — 1日を通した行程と上記の歩行ペースに慣れているお子様に向いています。これより小さなお子様にはクルーズバスツアーや桜ツアーをご検討ください。"
          }
        ]
      }

    "reviews_attribution": "운영자가 검증한 리뷰 1,148개 기준 평균 평점 4.9/5입니다. 이 페이지에는 평점 요약만 표시됩니다.",
    "unesco_fit_note": "unesco_fit=5 = 1 WHS (Seongsan Ilchulbong, inscribed 2007) + 1 Intangible Cultural Heritage of Humanity (Culture of Jeju Haenyeo, inscribed 2016, accessed via the Haenyeo Museum stop). Seongeup Folk Village is Korea's national folk heritage — NOT UNESCO — and does not contribute to this score.",
    "_internal_competing_products_note": "Comp set (internal only): Southern UNESCO sister product, same operator, $43/pax small-group rate as ceiling reference.",
    "competing_products": [
      "east-signature-nature-core",
      "jeju-grand-highlights-loop",
      "jeju-southern-top-unesco-spots-tour"
    ],
    "audit_summary": "East Jeju UNESCO-focused loop covering 5 distinct UNESCO heritage layers in one day: Olle Trail walking heritage (Hamdeok Course 19), Important Folklore Cultural Heritage (Seongeup Folk Village 1423 founding), Manjanggul-system lava tube (Ilchulland — UNESCO-property adjacent), Triple UNESCO Surtseyan tuff cone (Seongsan Ilchulbong), and UNESCO Intangible Cultural Heritage of Humanity (Jeju Haenyeo Museum, 2016 inscription). UNESCO-anchored counterpart to the signature-nature sister tour, which emphasizes Seolmundae Halmang mythology + Tadao Ando architecture instead.",
    "score_rationale": {
      "high_scores": {
        "unesco_focused_tour_fit=1.0": "5 explicit UNESCO heritage layers in one day — densest UNESCO concentration in catalog",
        "haenyeo_culture_fit=1.0": "UNESCO Intangible 2016 — full museum context + Seongsan demonstration in same day",
        "rainy_day_friendly_fit=1.0": "3 indoor fallback anchors (Seongeup hanok + Ilchulland cave + Haenyeo Museum 80% indoor)",
        "value_priced_fit=0.95": "Total ₩18,100 admission per adult for 5 UNESCO-grade anchors = catalog-leading UNESCO value",
        "feminist_history_fit=0.95": "Haenyeo Museum is the catalog's strongest women's-labor heritage anchor",
        "wwii_history_fit=1.0": "Hamdeok tunnels + Seongsan 18 caves both visible in day's narrative arc"
      },
      "low_scores": {
        "private_tour_fit=0.05": "Format is small-group fixed itinerary only",
        "west_jeju_fit=0.05": "Loop deliberately east-anchored",
        "language_japanese_fit=0.55": "WWII/colonial-history framing slightly sensitive for Japanese guests — guide trained for context"
      }
    },
    "differentiation_vs_signature_nature_sister": "Same Seongsan + Seongeup + Ilchulland anchors, but **UNESCO-anchored framing** (Hamdeok Olle 19 + Haenyeo Museum UNESCO Intangible 2016) vs. sister's **mythology + architecture framing** (Jeju Stone Park Seolmundae + Seopjikoji Tadao Ando). This tour = 5 UNESCO heritage layers + strongest rain-friendly anchor count + best ₩-per-UNESCO-anchor value; sister = mythology + Pulitzer architecture + 4 K-drama filming sites. Pair complementarily for guests with 2 days on Jeju.",
    "seasonal_window": {

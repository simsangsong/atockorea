    "anchor_poi_keys": [
      "hallasan_1100_wetland",
      "daepo_jusangjeolli_cliff",
      "songaksan",
      "cheonjeyeon_falls",
      "osulloc_tea_museum",
      "hyeopjae_beach"
    ],
    "audit_summary": "West-south Jeju authentic loop covering 4 distinct international/national designation layers in one day: Ramsar Wetland of International Importance (1100 Altitude Wetland, Site No. 1893), within Hallasan UNESCO World Heritage 2007 + Biosphere 2002 + National Park 1970 (1100 Wetland triple-overlap), Natural Monument No. 443 (Daepo Jusangjeolli columnar-jointing), and Natural Monument No. 378 (Cheonjeyeon Falls). Plus Songaksan's 104 m double-crater volcanic cone with WWII colonial-history coastal tunnels and Hyeopjae Beach's twin-beach + Biyangdo Island west-coast sunset finale. Alpine + double-crater + west-coast counterpart to the south-UNESCO sister tour, which emphasizes Hallasan Eoseungsaengak + Camellia Hill botanical layer + heritage tea finale.",
    "score_rationale": {
      "high_scores": {
        "ramsar_wetland_fit=1.0": "1100 Altitude Wetland is the catalog's only Ramsar site anchor — Site No. 1893 designated 2009",
        "quadruple_designation_fit=1.0": "1100 Wetland holds 4 overlapping international/national designations — rare globally",
        "double_crater_fit=1.0": "Songaksan is the catalog's only double-crater volcanic cone stop with full geological + WWII layering",
        "value_priced_fit=1.0": "Total ₩4,500 per adult for 6 substantive UNESCO/Ramsar/Natural Monument/sunset anchors = catalog-leading value",
        "varied_terrain_fit=1.0": "Alpine wetland + columnar cliffs + double-crater volcano + tea fields + waterfall + west-coast beach in one day = catalog-leading variety",
        "alpine_to_coastal_fit=1.0": "Only Jeju route covering 1,100 m alpine to sea-level sunset in a single day"
      },
      "low_scores": {
        "private_tour_fit=0.05": "Format is small-group fixed itinerary only",
        "east_jeju_fit=0.05": "Loop deliberately west-south anchored",
        "rain_fit=0.4": "Most stops outdoor — Osulloc + 1100 Rest Area only fallbacks; weather-sensitive tour",
        "winter_fit=0.7": "Route 1100 ice closure risk forces 1100 Wetland substitution ~5–10 days/year"
      }
    },
    "differentiation_vs_south_unesco_sister": "Same Jusangjeolli + Cheonjeyeon + Osulloc anchors, but **alpine Ramsar wetland + double-crater volcano + west-coast beach sunset emphasis** (1100 Wetland + Songaksan + Hyeopjae) vs. sister's **lower-elevation Hallasan trail + botanical + UNESCO arc emphasis** (Eoseungsaengak + Camellia Hill). This tour = 4 international/national designations + Songaksan double-crater + Hyeopjae sunset = catalog's most-varied terrain progression (alpine → coastal). Sister = 5 UNESCO/Natural Monument anchors + year-round bloom calendar + tea finale = catalog's densest UNESCO concentration. Pair complementarily for guests with 2 days on Jeju.",
    "seasonal_window": {
      "best_months": [
        "May",
        "June",
        "September",
        "October (1100 foliage)",
        "November"
      ],
      "good_months": [

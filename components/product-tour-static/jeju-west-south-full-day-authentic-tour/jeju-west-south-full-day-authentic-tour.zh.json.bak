            "intangible_heritage_fit": {
              "old": 0.8,
              "new": 0.45,
              "reasoning": "DOWNGRADED — only Cheonjeyeon Falls has clear intangible heritage (Chilseonyeo Festival). Songaksan has WWII forced-labor memorial significance but not UNESCO ICH category. Most of the route is natural heritage. 0.45 verified."
            },
            "beach_fit": {
              "old": 0.6,
              "new": 0.85,
              "reasoning": "UPGRADED — Hyeopjae IS the dedicated beach finale (one of Jeju's iconic west-coast beaches). 0.85 reflects beach as a major route theme."
            },
            "first_time_fit": {
              "old": 1.0,
              "new": 0.95,
              "reasoning": "Verified: covers UNESCO mountain wetland + columnar geopark + coastal trail + waterfall + tea + beach = 6 distinct Jeju essentials in one day. 0.95 — excellent first-Jeju overview, particularly comprehensive for natural-heritage focus."
            },
            "value_for_money_fit": {

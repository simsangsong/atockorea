        "July (Hyeopjae swim peak)",
        "August",
        "March"
      ],
      "caveat_months": [
        "December",
        "January (Route 1100 ice)",
        "February"
      ],
      "peak_crowd_months": [
        "July",
        "August (Hyeopjae)"
      ]
    },
    "kb_anchor_version": "1.20"
  },

        "_score_audit": {
          "_methodology": "0-1 float scale. Indoor ratio computed time-weighted per Jason's methodology.",
          "deltas_applied": {
            "unesco_fit": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified: 2 UNESCO-related stops — 1100 Wetland (inside Hallasan UNESCO + Ramsar) + Jusangjeolli (UNESCO Global Geopark). Songaksan, Cheonjeyeon, O'sulloc, Hyeopjae are non-UNESCO. 2/7 = 0.85 (strong UNESCO presence but not pure)."
            },
            "walking_level": {
              "old": 0.6,
              "new": 0.65,
              "reasoning": "Verified totals: 1100 Wetland 1 km flat boardwalk, Jusangjeolli 0.5 km flat, Songaksan 2.8 km + 108 m elevation, Cheonjeyeon 0.5 km + stairs, O'sulloc 1 km flat, Hyeopjae 0.5 km flat. Total ~6 km + Songaksan elevation. 0.65 verified — Songaksan is the demanding stop."
            },
            "scenic_level": {
              "old": 0.8,
              "new": 0.95,
              "reasoning": "UPGRADED — verified 7 distinct landscapes: alpine wetland boardwalk, basalt columnar coast, coastal cliff trail with islands view, three-tier waterfall, tea fields, west-coast emerald beach. Most landscape-diverse Jeju route. 0.95."
            },
            "photo_level": {
              "old": 0.8,
              "new": 0.95,
              "reasoning": "Verified: 7 hero shots — wetland boardwalk + Hallasan, basalt columns, Songaksan with Sanbangsan + Marado, nymph bridge, tea fields, Biyangdo + emerald water. Among most photogenic Jeju routes."
            },
            "iconic_landmark_fit": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified: 3 universally iconic (Jusangjeolli, O'sulloc, Hyeopjae); 1100 Wetland regionally known; Songaksan + Cheonjeyeon famous to Jeju visitors. 0.85 calibrated."
            },
            "stroller_fit": {
              "old": 0.6,
              "new": 0.55,
              "reasoning": "Verified: 1100 Wetland boardwalk (good), Jusangjeolli boardwalk (good), Songaksan boardwalk (mostly good — gentle stairs), O'sulloc flat (good), Hyeopjae beach ramp (good), Cheonjeyeon stairs (NOT stroller-friendly). 5/6 substantive stroller-friendly = 0.55."
            },
            "mobility_friendly_fit": {
              "old": 0.6,
              "new": 0.55,
              "reasoning": "Same logic — 5/6 mobility-friendly with Cheonjeyeon stairs being the exception. Slight upgrade beyond mechanical 0.6 not warranted because Songaksan elevation also limits some seniors."
            },
            "indoor_ratio": {
              "old": 0.4,
              "new": 0.15,
              "reasoning": "MAJOR CORRECTION using time-weighted method: 1100 Wetland 10%, Jusangjeolli 0%, Songaksan 0%, Cheonjeyeon 5%, O'sulloc 50%, Hyeopjae 0%. Without lunch: 30/330 ≈ 0.09. With lunch: 78/390 = 0.20. Catalog value 0.15 represents both — predominantly outdoor route. Mechanical Phase 1 conversion 0.4 was significantly overstated."
            },
            "weather_sensitivity": {
              "old": 0.6,
              "new": 0.85,
              "reasoning": "UPGRADED — verified ~85% outdoor stop time. 1100 Wetland subject to road closure in winter; Songaksan exposed sun + wind; Hyeopjae beach weather-dependent. Highest weather sensitivity in catalog after pure-beach tours."
            },
            "rain_fit": {
              "old": 0.6,
              "new": 0.35,
              "reasoning": "DOWNGRADED — only O'sulloc Tea Museum interior is reliable rain refuge. 1100 Wetland + Songaksan + Cheonjeyeon + Hyeopjae all rain-affected; Jusangjeolli also exposed. Verified poor rain hedge."

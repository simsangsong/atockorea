  "routeShapeIntro": {
    "title": "行程路线一览",
    "subtitle": "西部—南部济州环线，比旅游服务团队的南部UNESCO线路刻意减少遗产分量。南部线路侧重御乘生态步道与UNESCO地质，本线路则更注重海岸风光、当地饮食文化及西部隐藏景点。"
  },
  "whyTourWorks": {
    "bestFor": [
      "希望在一天内体验UNESCO汉拏山与济州咖啡厅海滩的旅客",
      "追逐多样景观（高地湿地→海岸悬崖→茶田→白沙海滩）的摄影爱好者",
      "停留两天或以下的初次游济州旅客",
      "希望行程均衡、节奏舒适的情侣及成人家庭",
      "偏好固定路线结构而非私人司机灵活性的旅客"
    ],
    "lessIdealFor": [
      "希望在某一景点延长自由时间的旅客（本行程为固定路线巡回）",
      "当天邮轮旅客——17:30至18:15的挟才收尾与大多数邮轮离港时段冲突",
      "希望深度汉拏山登山的旅客（本路线仅限1100高地湿地观景）",
      "每个景点都需要轮椅通道的旅客（天帝渊约80级石阶；松岳山2.6公里非铺设步道）",
      "独游预算旅客（小团按人计价；轻松节奏更适合情侣和家庭）"
    ],
    "routeLogicSections": [
      {
        "title": "为何如此安排路线",
        "icon": "route",
        "iconBg": "bg-sky-50/80",
        "iconColor": "text-sky-600",
        "items": [
          {
            "label": "无需登山即可获得UNESCO认证",
            "detail": "大多数UNESCO汉拏山行程至少包含90分钟步行。本路线使用1100高地湿地——同一个UNESCO生物圈，同样的火山景观，但以几乎对所有人无障碍的平坦木栈道环线呈现。"
          },
          {
            "label": "咖啡厅海滩收尾优于仅以博物馆结束",
            "detail": "标准南部环线在雪绿茶博物馆结束，18:00关门，感觉像全日在收尾。本路线加入挟才海滩及咖啡厅一条街作为最后一站——全日以日落海岸咖啡厅而非博物馆停车场结束。"
          },
          {
            "label": "一天涵盖两个海岸",
            "detail": "大多数济州日行程只停留一个海岸。本路线刻意同时覆盖南海岸（柱状节理、天帝渊、松岳山）和西海岸（雪绿、挟才）。对1日游济州旅客而言，这是在可接受的额外车程成本下最大化覆盖范围的路线。"
          },
          {
            "label": "同一旅游服务团队，同样的「无强制购物」政策",
            "detail": "本行程由与南部UNESCO行程相同的旅游服务团队（Love Korea Tours）运营。「无购物」条款和四个接送点安排同样适用。评论中一致提及导游姓名（Steven、Chloe、Sunny），说明在不付私人游费用的前提下仍能获得个人关注。"
          }
        ]
      },
      {
        "title": "步行负担的真实感受",
        "icon": "footprints",
        "iconBg": "bg-amber-50/80",
        "iconColor": "text-amber-600",
        "items": [
          {
            "label": "1100高地湿地是最轻松的停留",
            "detail": "约1公里的平坦木栈道环线。适合所有年龄和体能层次。木栈道上适合轮椅通行。"
          },
          {
            "label": "松岳山是最长的活跃步行",
            "detail": "2.6公里海岸环形步道，海拔爬升低。完整环线约60至90分钟；1.5公里半圈可到达最强观景点，时间不够时可选。"
          },
          {
            "label": "天帝渊石阶是唯一要求较高的路段",
            "detail": "从上层观景台无需石阶。到达2号和3号瀑布需要约80级石阶下行和返回。"
          }
        ]
      },
      {
        "title": "天气与季节变化时的应对",
        "icon": "cloud-snow",
        "iconBg": "bg-sky-50/80",
        "iconColor": "text-sky-600",
        "items": [
          {
            "label": "1100道路大雪关闭",
            "detail": "通常每个冬天1至3天。旅游服务团队以三房山（山房山）寺庙群或增加挟才时间替代。"
          },
          {
            "label": "夏季挟才下午人潮最旺",
            "detail": "7至8月的咖啡厅一条街座位在16:00至18:00之间达到高峰。最受欢迎的咖啡厅可能需要排队。"
          },
          {
            "label": "天帝渊水量依季节而异",
            "detail": "6至9月夏雨后水量最强。冬季水量较低，但拍摄条件更为清晰。"
          }
        ]
      }
    ]
  },

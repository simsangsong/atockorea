    {
      "id": "faq",
      "component": "TourFaqSection",
      "props": {
        "staticQuestions": [
          {
            "id": "first-time",
            "question": "済州初訪問者に良い選択ですか？",
            "answer": "はい。漢拏山の景観、火山海岸、滝のウォーク、茶畑の雰囲気、そしてリラックスした涯月のフィナーレという、バランスの良い一日体験ができます。"
          },
          {
            "id": "walking",
            "question": "歩行難易度は高いですか？",
            "answer": "特別に難しくはありません。御乗生岳が最もアクティブなセクションで階段が多いですが、残りの見どころは概ねやさしい歩行です。全体の歩行距離は約4.5〜5.5km。"
          },
          {
            "id": "rain",
            "question": "雨の日もツアーは実施しますか？",
            "answer": "はい。雨でもルートは実施できますが、御乗生岳や露出度の高い海岸セクションが短縮または調整される場合があります。ガイドが現地で最適な判断を行います。"
          },
          {
            "id": "parents",
            "question": "親や年配の家族との旅行に適していますか？",
            "answer": "はい、多くの場合適しています。御乗生岳の階段と天帝淵の階段に不安がなければ、大人ファミリーの旅に非常に向いています。"
          },
          {
            "id": "children",
            "question": "お子様連れで参加できますか？",
            "answer": "はい。短いウォークと一日の活動量についてこられる8歳前後以上のお子様に特に適しています。O'sullocの緑茶アイスクリームと涯月のカフェが人気見どころです。"
          },
          {
            "id": "order",
            "question": "見どころの順序は現地状況で変わることがありますか？",
            "answer": "はい。山岳の天候、海岸の風、交通状況、混雑度がすべてルートの小さな変更につながる場合があります。ガイドがその日の最適な順序を判断します。"
          },
          {
            "id": "lunch",
            "question": "昼食は含まれていますか？",
            "answer": "商品の条件によります。昼食時間はルートに組み込まれていますが、食事そのものが含まれるかどうかは予約時にご確認ください。通常、昼食は自己負担（約₩15,000）です。"
          },
          {
            "id": "why-eoseungsaengak",
            "question": "なぜ御乗生岳から始まるのですか？",
            "answer": "グループのエネルギーが最も高い朝に、本物の漢拏山体験で一日を開始するためです。長時間のハイキングなしで本格的な漢拏山の感覚を味わえます。"
          },
          {
            "id": "why-jusangjeolli",
            "question": "漢拏山の後に大浦柱状節理を訪れる理由は？",
            "answer": "済州の火山の物語が山岳地形から劇的な玄武岩海岸へと自然に展開するためです。御乗生岳で見た溶岩が海で冷えてこの形になったという地質学的なつながりが生まれます。"
          },
          {
            "id": "why-osulloc",
            "question": "O'sullocが涯月より先の理由は？",
            "answer": "O'sullocが天帝淵の後の雰囲気を和らげることで、涯月がより自然にリラックスした感じに見えます。"
          },
          {
            "id": "later-structure",
            "question": "後半がこのような構成になっている理由は？",
            "answer": "昼食と天帝淵が午前のよりオープンなセクションの後でリズムを整え、O'sullocがより軽い雰囲気を加え、涯月がリラックスしたフィナーレを自然に開きます。"
          }
        ]
      }
    },

    {
      "id": 2,
      "author": "James K.",
      "avatar": "https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&q=80",
      "location": "Hong Kong",
      "date": "2024年3月",
      "rating": 5,
      "title": "特に快適な締めくくりのある素晴らしい南西ルート",
      "text": "韓国でいくつかのツアーに参加しましたが、このツアーが際立っていたのは順序がとてもよく組まれていたからです。ガイドは漢拏山、断崖、天帝渊の間のリズムをスムーズに扱いました。",
      "helpful": 18,
      "verified": true,
      "tripType": "家族",
      "photos": []
    },
    {
      "id": 3,
      "author": "Yuki T.",
      "avatar": "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=100&q=80",
      "location": "Tokyo",
      "date": "February 2024",
      "rating": 4,
      "title": "特に涯月で一日を終えるのが気に入りました",
      "text": "全体的な体験はとても良かったです。御乗生岳は期待以上に良いスタートで、O'sullocは涯月の前の完璧な停留所でした。涯月でもう少し時間を過ごしたかったので4点にしました。",
      "helpful": 12,
      "verified": true,
      "tripType": "一人旅",
      "photos": [
        "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=400&q=80"
      ]
    },
    {
      "id": 4,
      "author": "Michael R.",
      "avatar": "https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&q=80",
      "location": "Sydney",
      "date": "February 2024",
      "rating": 5,
      "title": "ルートは予想以上にバラエティに富んでいました",
      "text": "主に景色のために参加しましたが、最も印象に残ったのは一日全体がいかによく繋がっていたかでした。漢拏山、玄武岩の断崖、滝、茶畑、涯月の海岸がすべて一つの連続した物語の一部のように感じられ、小グループ形式がすべての移行をスムーズに保ちました。",
      "helpful": 31,
      "verified": true,
      "tripType": "友人",
      "photos": []
    }

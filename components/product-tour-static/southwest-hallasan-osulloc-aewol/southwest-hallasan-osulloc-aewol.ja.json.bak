    },
    {
      "id": "why-eoseungsaengak",
      "question": "なぜ御乗生岳から始まるのですか？",
      "answer": "グループのエネルギーが最も高い朝に、本物の漢拏山体験で一日を開始するためです。長時間のハイキングなしで本格的な漢拏山の感覚を味わえます。"
    },
    {
      "id": "why-jusangjeolli",
      "question": "漢拏山の後に大浦柱状節理を訪れる理由は？",
      "answer": "済州の火山の物語が山岳地形から劇的な玄武岩海岸へと自然に展開するためです。御乗生岳で見た溶岩が海で冷えてこの形になったという地質学的なつながりが生まれます。"
    },
    {
      "id": "why-osulloc",
      "question": "O'sullocが涯月より先の理由は？",
      "answer": "O'sullocが天帝淵の後の雰囲気を和らげることで、涯月がより自然にリラックスした感じに見えます。"
    },
    {
      "id": "later-structure",
      "question": "後半がこのような構成になっている理由は？",
      "answer": "昼食と天帝淵が午前のよりオープンなセクションの後でリズムを整え、O'sullocがより軽い雰囲気を加え、涯月がリラックスしたフィナーレを自然に開きます。"
    }
  ],
  "guestReviews": [
    {
      "id": 1,
      "author": "Sarah M.",
      "avatar": "https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&q=80",
      "location": "Singapore",
      "date": "2024年3月",
      "rating": 5,
      "title": "一日で済州南西部を見る非常にバランスの取れた方法",
      "text": "ルートの流れは素晴らしかったです。漢拏山から始めたことで一日に実際のモメンタムが生まれ、その後の柱状節理がさらに印象的に感じられました。O'sullocから涯月へのルートの移り方が特に気に入りました。",
      "helpful": 24,
      "verified": true,
      "tripType": "カップル",
      "photos": [
        "https://images.unsplash.com/photo-1506744038136-46273834b3fb?w=400&q=80",

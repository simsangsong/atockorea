    "audit_summary": "South Jeju UNESCO + heritage signature loop covering 5 distinct UNESCO/Natural Monument layers in one day: Hallasan UNESCO World Heritage 2007 + Biosphere 2002 (Eoseungsaengak trail), Camellia Hill (largest camellia arboretum in the East, 6,000 trees / 500+ species from 80 countries, year-round bloom), Cheonjeyeon Falls (Natural Monument No. 378), Daepo Jusangjeolli Cliff (Natural Monument No. 443, East Asia's premier columnar-jointing site), Osulloc Tea Museum (Korea's largest green-tea field + 2009 Korea Architecture Award). Botanically-anchored counterpart to the west-south-authentic sister tour, which emphasizes Hallasan 1100 Wetland Ramsar site + Songaksan double-crater + Hyeopjae Beach.",
    "score_rationale": {
      "high_scores": {
        "unesco_anchor_count=5": "5 distinct UNESCO/Natural Monument layers in one day — densest UNESCO concentration in catalog Jeju routes",
        "year_round_attraction_fit=1.0": "Camellia Hill's year-round bloom calendar + Osulloc indoor museum + Hallasan all-season = no seasonal-risk tour",
        "honeymoon_fit=1.0": "Camellia + Osulloc + waterfalls = honeymoon-classic south-Jeju trifecta",
        "geology_enthusiast_fit=1.0": "Hallasan Triple Natural designation + Jusangjeolli East Asia premier columnar-jointing",
        "botanical_enthusiast_fit=1.0": "Catalog's only stop with the East's largest camellia arboretum",
        "tea_enthusiast_fit=1.0": "Osulloc + Seogwang Dawon = Korea's tea-culture flagship destination"
      },
      "low_scores": {
        "private_tour_fit=0.05": "Format is small-group fixed itinerary only",
        "east_jeju_fit=0.05": "Loop deliberately south + southwest anchored",
        "off_beaten_path_fit=0.4": "All anchors are popular tourist sites — not for crowd-avoiders"
      }
    },
    "differentiation_vs_west_south_authentic_sister": "Same Jusangjeolli + Cheonjeyeon + Osulloc anchors, but **UNESCO + botanical emphasis** (Hallasan Eoseungsaengak + Camellia Hill) vs. sister's **alpine wetland + double-crater volcano + west-coast beach emphasis** (Hallasan 1100 Wetland Ramsar + Songaksan + Hyeopjae Beach). This tour = 5 UNESCO/Natural Monument anchors + year-round bloom calendar + tea-culture finale; sister = Ramsar wetland + WWII coastal tunnels + emerald-water beach sunset. Pair complementarily for guests with 2 days on Jeju.",
    "seasonal_window": {
      "best_months": [
        "April",
        "May",
        "October",
        "November",
        "March (camellia tail + cherry start)"

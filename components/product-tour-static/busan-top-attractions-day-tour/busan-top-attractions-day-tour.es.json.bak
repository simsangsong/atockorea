            ],
            "whyOnRoute": "Tres estaciones de metro cubren la mayoría de zonas hoteleras de Busan. El orden de recogida aprovecha el recorrido hacia el noreste (Yonggungsa) sin desvíos.",
            "_poi_meta": {
              "poi_key": "OPS_busan_pickup_central",

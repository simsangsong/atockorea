    "audit_summary": "East-Jeju Hydrangea Festival route — 9-hr small-group minicoach loop. 5 substantive POI anchors: 1 emerald-coast beach (Hamdeok) + 1 Joseon folk village (Seongeup, National Folklore Cultural Heritage No. 188) + 1 triple-ユネスコ tuff cone (Seongsan: World Heritage 2007 + Global Geopark 2010 + Biosphere 2002) + 2 hydrangea festival anchors (Ilchul Land Micheon Cave + Hueree Natural Park). Designed for **June peak hydrangea window (June 10–25)** with Hueree greenhouse + Ilchul Land lava-tube + Seongeup hanok interiors as the **3-tier indoor weather-fallback stack**. Cross-batch reuse: 4 of 5 substantive bodies imported verbatim (14a Seongsan, 14b Hamdeok + Seongeup + Ilchulland); only Hueree authored fresh.",
    "score_rationale": {
      "high_scores": {
        "east_jeju_fit=1.0": "All 5 substantive stops are on the east-coast/east-inland corridor",
        "hydrangea_festival_anchor_count=2": "Ilchul Land + Hueree both during June peak",
        "unesco_triple_anchor_fit=1.0": "Seongsan carries simultaneous triple-ユネスコ designation",
        "natural_monument_anchor_count=2": "Seongsan tuff cone + Jeju Black Pig (Hueree show)",
        "year_round_flower_park_fit=1.0": "Hueree's 5-festival rotation guarantees active festival 320+ days/year",
        "macro_floral_fit=1.0": "Two hydrangea festival venues — peak macro-photography opportunities"
      },
      "low_scores": {
        "wheelchair_fit=0.05": "Seongsan rim climb has 182m of stairs; Hueree paths are gravel/grass",
        "winter_visitors_seeking_floral_peak": "Hydrangea peak is mid-June — winter visitors should look at the southwest tour's Camellia Hill year-round bloom",
        "private_tour_fit=0.05": "Fixed small-group itinerary; private re-routing would forfeit the operator's vetted lunch venues + bloom-status calibration"
      }
    },
    "differentiation_vs_southwest_hydrangea_sister": "Same 'hydrangea festival' product family, but **east-ユネスコ + heritage emphasis**: triple-ユネスコ Seongsan + National Folklore Heritage Seongeup + Hamdeok emerald + 2 hydrangea festival venues (Ilchul Land + Hueree). The southwest sister covers **west-coast beach + columnar joints + Camellia Hill hydrangea tunnel + Osulloc tea fields** — a more garden-and-geology-coded, lower-climb route. Booking matrix: guests with strong ユネスコ interest + willing to climb Seongsan should book east; guests with lower mobility tolerance or stronger west-coast/beach interest should book southwest.",
    "seasonal_window": {
      "best_months": [
        "June (peak hydrangea)",
        "May (early hydrangea + late cherry)",
        "October",
        "April"
      ],
      "good_months": [
        "March",
        "September",
        "November"
      ],
      "low_season_months": [
        "December",
        "January",
        "February"
      ],
      "snow_closure_risk": "Seongsan rim stairs close if iced — winter substitutes typically Seopjikoji",
      "typhoon_window": "August — typhoon-track season; tour reschedule policy applies"
    },
    "kb_anchor_version": "1.21"
  },

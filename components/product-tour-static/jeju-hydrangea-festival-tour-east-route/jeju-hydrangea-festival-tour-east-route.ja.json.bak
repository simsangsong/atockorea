        "description": "Batch 4 deep enhancement — descriptions raised to 700-1300+ chars; KB-backed metadata on all attraction stops; product profile recalibrated with verified-fact 0-1 float scores. Time-weighted indoor_ratio computation per Fix 1 methodology.",
        "_score_audit": {
          "_methodology": "0-1 float scale. Indoor ratio computed time-weighted with Fix 1 methodology applied to Seongeup (30%) and Ilchul Land (30%).",
          "deltas_applied": {
            "unesco_fit": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified: Seongsan = UNESCO World Heritage. Tour name says 'Seongeup UNESCO' but Seongeup is Korean National Folklore Cultural Heritage, NOT UNESCO. 1/6 stops actually UNESCO. 0.85 reflects strong cultural-heritage anchor + 1 UNESCO."
            },
            "intangible_heritage_fit": {
              "old": 0.8,
              "new": 0.75,
              "reasoning": "Verified: Seongsan haenyeo demos (UNESCO ICH) + Seongeup folkways + omegisul brewery. 3/6 with intangible heritage value. 0.75 calibrated."
            },
            "walking_level": {
              "old": 0.6,
              "new": 0.55,
              "reasoning": "Verified: Hamdeok 0.5 km flat, Seongeup ~1 km flat olle, Seongsan photo+optional climb, Micheon 365 m flat, Ilchul Land 1 km flat, Hueree 1.5–2 km flat. Total ~5 km flat. 0.55 calibrated — gentler than mechanical 0.6."
            },
            "scenic_level": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "Verified: 6 distinct landscapes (turquoise beach, Joseon walled town, UNESCO peak, lava tube + gardens, hydrangea fields). 0.85 — strong but not catalog-leading (west-south tour at 0.95)."
            },
            "photo_level": {
              "old": 1.0,
              "new": 0.9,
              "reasoning": "Verified: 6 hero shots + dedicated festival photography (hydrangea Hueree). 0.90 calibrated."
            },
            "iconic_landmark_fit": {
              "old": 0.8,
              "new": 0.85,
              "reasoning": "Verified: Seongsan universally iconic + Hamdeok Top 3 Jeju beach + Seongeup folklore heritage + Hueree regional festival icon. 0.85 calibrated."
            },
            "indoor_ratio": {
              "old": 0.4,
              "new": 0.2,
              "reasoning": "CORRECTION using time-weighted method (Fix 1 + Batch 4 methodology): 105.75 indoor / 390 total = 0.27 with lunch; 57.75 / 330 = 0.18 without. Catalog 0.20 represents both. Mechanical 0.4 overstated."
            },
            "weather_sensitivity": {
              "old": 1.0,
              "new": 0.85,
              "reasoning": "VERIFIED 0.85 — hydrangea blooms are weather-affected; outdoor stops dominate; Hamdeok beach + Seongsan exposed. Higher than typical because of hydrangea festival's bloom-window dependency."
            },

    "reviews_attribution": "Reseñas verificadas por AtoC Korea. 4.7/5 average across 168 verified bookings.",
    "unesco_fit_note": "unesco_fit=5: two UNESCO Natural Heritage sites on route from the Jeju Volcanic Island and Lava Tubes inscription (2007) — Manjanggul Cave and Seongsan Ilchulbong. Highest possible UNESCO density for a one-day Jeju tour.",
    "competing_products": [
      "southwest-hallasan-osulloc-aewol",
      "east-signature-nature-core",
      "jeju-southern-top-unesco-spots-tour",
      "jeju-eastern-unesco-spots-day-tour"
    ],
    "audit_summary": "Highlights loop covers Jeju's NORTH (Hallasan UNESCO Triple-stack at Eoseungsaengak), SOUTH (Daepo Jusangjeolli columnar lava + Jeongbang ocean-falling waterfall), and EAST (Seongsan Ilchulbong Triple-UNESCO Surtseyan tuff cone). The single most representative single-day intro to Jeju for first-time visitors, anchored by 3 of the island's 4 UNESCO-status volcanic sites + the Asia-unique ocean-falling waterfall.",
    "score_rationale": {
      "high_scores": {
        "first_time_jeju_fit=1.0": "Single best intro to Jeju's UNESCO + volcanic identity; covers 3 cardinal directions (N/S/E) in one day",
        "unesco_taste_fit=1.0": "Hallasan UNESCO + Seongsan Triple UNESCO in same day = unmatched in catalog",
        "geology_enthusiast_fit=1.0": "Three distinct volcanic landforms (parasitic cone, columnar lava, tuff cone) sequenced as eruptive history",
        "instagrammable_fit=1.0": "Four of the most photographed Jeju locations on a single loop",
        "asia_unique_landform_fit=1.0": "Jeongbang = only ocean-falling waterfall in Asia"
      },
      "low_scores": {
        "private_tour_fit=0.05": "Format is small-group fixed itinerary only",
        "wheelchair_accessible_anchor_fit=0.4": "Hallasan trail + Jeongbang 130 steps + Seongsan ascent block wheelchair access",
        "off_season_fit=0.6": "Winter Hallasan accessibility caveat + cone summit cold",
        "rain_fit=0.5": "All 4 substantive stops are outdoor; no indoor fallback anchor",
        "west_jeju_fit=0.3": "Loop deliberately excludes west (covered by sister tour southwest-hallasan-osulloc-aewol)"
      }
    },
    "differentiation_vs_southwest_sister": "Same Hallasan + Jusangjeolli openers, but **east-coastal anchor at Seongsan Triple UNESCO** (sister terminates at Aewol Cafe Street west-coast). This tour = UNESCO + geology emphasis; sister = tea culture + sunset cafe lifestyle. Pair complementarily for guests with 2 days on Jeju: this loop on Day 1 (UNESCO landmarks), sister on Day 2 (southwest cultural depth).",
    "seasonal_window": {
      "best_months": [
        "April",
        "May",
        "October",
        "November"
      ],
      "good_months": [
        "March",
        "June",

    "_seasonalSummary": "全島環線，一日內涵蓋濟州東部、南部及西部。各地區天氣可能有所差異——海岸景點全年氣候溫和，但內陸路段可能較為涼爽且風勢較強。",
    "_seasonalTemperatures": [
      {
        "season": "春季（3至5月）",
        "range": "8–22°C",
        "notes": "四月初東部海岸櫻花盛開；行車條件舒適。"
      },
      {
        "season": "夏季（6至8月）",
        "range": "22–30°C",
        "notes": "天氣炎熱，但沿海行駛時溼度較為緩和。天帝淵瀑布水量在此季節達到高峰。"
      },
      {
        "season": "秋季（9至11月）",
        "range": "10–24°C",
        "notes": "最佳季節——所有景點的能見度最為清晰，步行溫度舒適。"
      },
      {
        "season": "冬季（12至2月）",
        "range": "3–10°C",
        "notes": "城山日出峰頂及大浦柱狀節理懸崖的風寒效應顯著，各景點遊客較少。"
      }
    ]
  },

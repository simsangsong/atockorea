    "source_of_truth_note": "Runtime recommendation reads Supabase tour_matching_profiles. Cruise products require user_port parameter for variant selection.",
    "port_routing_split": {
      "applied_at": "2026-04-27",
      "previous_state": "Single itineraryStops representing one generic cruise route.",
      "schema_change": "itineraryStops -> itinerary_variants (port-keyed array)",
      "ports_introduced": [
        {
          "port_id": "jeju_port",
          "label": "Jeju Port (Northern Terminal)",
          "route_focus": "East coast UNESCO + folk"
        },
        {
          "port_id": "gangjeong_port",
          "label": "Gangjeong Port (Seogwipo Terminal)",
          "route_focus": "Hallasan + SW coast geology + market"
        }
      ],
      "rationale": "Cruise ships call at different Jeju ports depending on route. Jeju Port (north) and Gangjeong Port (south, in Seogwipo) are 60+ km apart, so the day-trip route differs entirely. A single itinerary misrepresented the actual product served at each port.",
      "matching_implications": [
        "When user_port is known (cruise booking context), score only the matched variant's poi_tags_in_variant / theme_tags_in_variant.",
        "When user_port is unknown, fall back to product profile.poi_tags (union).",
        "Variant-level indoor_ratio_in_variant / weather_sensitivity_in_variant override product profile values when a specific port is selected."
      ],
      "downstream_actions": [
        "Frontend: add port selector UI (radio or chip) before itinerary renders. Default to 'Select your cruise port' empty state with both variant previews visible.",
        "Supabase: add port_id (text, nullable) column to bookings table; FK to a new cruise_ports reference table with rows for jeju_port, gangjeong_port.",
        "Cruise routing note: use the guest port when available; otherwise use the general cruise route profile.",
        "Pricing review: validate whether bus / small group pricing differs by port — Gangjeong route includes Hallasan 1100 which adds drive time and toll vs Jeju Port's east-coast loop.",
        "Existing bookings: backfill port_id where derivable from itinerary or pickup_base; flag rest as null for manual review.",
        "Locale (ko): translate port_label, port_label_short, route_focus, and stop names/descriptions for Korean users."
      ]
    },
    "audit_summary": {
      "kept_from_product_json": [
        "product_type",

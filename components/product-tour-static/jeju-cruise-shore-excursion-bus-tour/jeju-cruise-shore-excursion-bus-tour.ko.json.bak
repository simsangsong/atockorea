  "staticQuestions": [
    {
      "id": "port-routing",
      "question": "내 크루즈가 어느 항구에 기항하는지 어떻게 알 수 있나요?",
      "answer": "크루즈 예약 확인서에 기항 항구가 명시되어 있습니다. 예약 시 항구를 알려주시면 코스를 확정합니다."
    },
    {
      "id": "cruise-return",
      "question": "제시간에 배로 돌아올 수 있나요?",
      "answer": "네, 두 코스 모두 16:30~17:00 크루즈 터미널 도착을 목표로 하며, 교통 지연에 대비한 여유 시간을 포함합니다. 크루즈 선박 출항 시각을 실시간으로 파악하며 운행합니다."
    },
    {
      "id": "different-port",
      "question": "기항 항구가 변경되면 어떻게 되나요?",
      "answer": "변경 사항을 알게 되는 즉시 알려주세요. 항구에 맞게 코스를 바꿔 드립니다. 항구별 코스가 있는 이유가 바로 이것입니다."
    },
    {
      "id": "first-time",
      "question": "제주를 처음 방문하는 분에게 적합한가요?",
      "answer": "네, 크루즈 기항지 시간 내에 제주 핵심 명소를 균형 있게 볼 수 있는 투어입니다."
    },
    {
      "id": "walking",
      "question": "도보 이동이 힘들지 않나요?",
      "answer": "보통 수준의 도보와 활동적인 구간이 포함됩니다."
    },
    {
      "id": "family",
      "question": "가족 여행에 적합한가요?",
      "answer": "하루 종일 이동 가능한 어린이가 동반하는 가족에게 적합합니다."
    },
    {
      "id": "seniors",
      "question": "어르신도 참여할 수 있나요?",
      "answer": "계단과 비포장 지형이 포함되어 있어, 활동적인 어르신께 권장합니다."
    },
    {
      "id": "children",
      "question": "권장 최소 연령은 몇 세인가요?",
      "answer": "만 6세 이상, 하루 종일 이동과 도보 활동이 가능한 어린이에게 적합합니다."
    },
    {
      "id": "rain",
      "question": "비가 와도 투어가 진행되나요?",
      "answer": "노출 구간이 있어 강우 시 일부 경유지가 단축되거나 대체될 수 있습니다."
    },
    {
      "id": "lunch",
      "question": "점심 식사가 포함되어 있나요?",
      "answer": "점심 시간은 일정에 포함되어 있습니다. 식사비 포함 여부는 예약 시 확인하세요."
    },
    {
      "id": "pickup",
      "question": "어디서 픽업이 이루어지나요?",
      "answer": "크루즈 터미널 도착홀에서 가이드가 직접 맞이합니다. 정확한 픽업 시각은 전날 저녁 확인됩니다."
    }
  ],

    ],
    "fix_passes": {
      "v12": "P0+P1 — pickup_dropoff Schema A unification, routeFlowStops type-based, competing_products → internal slugs, anchor_poi_keys aligned",
      "v13": "P1.5 — pickup_dropoff Schema A.2 → A.1; practicalAccordionItems / routePhases / seasonalVariations unified to V4 canonical (no Tailwind in data)",
      "v14": "P2 — _publication uniform; duration formatting standardized; glanceItems Duration added where missing",
      "v15": "P3 round 1 — SEO trim. seo.pageTitle rewritten to ≤65 chars (was 14/25 over 70); seo.metaDescription rewritten to ≤168 chars (was 25/25 over 170). primaryKeywords and ogImage unchanged. Hero/OG images, POI verification, review imports, and routePhases enrichment deferred to later P3 rounds.",
      "v17_schema_unification": {
        "date": "2026-04-28",
        "description": "Phase 1: Converted product profile scores from 1-5 int scale to 0-1 float scale to match the 3 Step 3 new tours. Mapping 1→0.20, 2→0.40, 3→0.60, 4→0.80, 5→1.00. Mechanical conversion preserves ordinal information; verified-fact recalibration happens in subsequent enhancement batches.",
        "fields_converted": 43,
        "fields_skipped": 0,
        "fields_already_float": 0
      },
      "v17_batch7_enhancement": {
        "date": "2026-04-29",
        "description": "Batch 7 deep enhancement — private charter pair (Jeju + Seoul). Both tours have 4 route options as itineraryStops (East/West/South/Custom for Jeju; Gapyeong/DMZ-Paju/Everland-Folk/Custom for Seoul). Each route option enhanced with 1,000+ char descriptions weaving verified facts about constituent POIs into a coherent route narrative. product profile recalibrated to verified-fact 0-1 float scores using cross-route weighted averaging. private_tour_fit, customizable_route_fit, flexibility_fit set from None to 1.0. 9 new POIs added to KB (v1.9 → v1.10): udo_island, manjanggul_lava_tube, sanbangsan_mountain, sangumburi_crater, yakcheonsa_temple, garden_of_morning_calm, petite_france, everland, korean_folk_village_yongin. DMZ POIs and Nami Island deferred to Batch 8.",
        "_score_audit": {
          "_methodology": "0-1 float scale per Phase 1 standard. Both tours are private 9-10hr charters with 4 route options (East/West/South/Custom for Jeju; Gapyeong/DMZ-Paju/Everland-Folk/Custom for Seoul). Scores are weighted averages across the recommended routes, with extreme-outlier dimensions weighted toward the realistic middle (e.g. UNESCO score reflects average across routes — Route 1 maxes UNESCO, but weighted average ~0.65). Charter-format dimensions (private_tour_fit, customizable_route_fit, flexibility_fit) are set to 1.0 by definition. Walking_level and indoor_ratio are time-weighted averages across the typical day.",
          "deltas_applied": {
            "private_tour_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Both tours are per-vehicle private charters by definition. Was previously None (unset)."
            },
            "customizable_route_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Three recommended routes plus a fully custom option. Both tours fully customizable. Was previously None."
            },
            "flexibility_fit": {
              "old": null,
              "new": 1.0,
              "reasoning": "VERIFIED — Driver-guide adapts pacing, order, lunch, optional add-ons (Udo ferry, Smart Queue). Was previously None."
            },
            "small_group_fit": {
              "old": 0.2,
              "new": 0.15,
              "reasoning": "Verified — these are PRIVATE charters not small-group. 0.15 reflects that a 1-vehicle-of-9 booking still functions as a small private group, but the product type is private not small_group."
            },
            "bus_fit": {
              "old": 0.2,
              "new": 0.05,
              "reasoning": "Verified — private charter = sedan/SUV/van, never bus. 0.05 reflects near-zero bus fit (only the very largest groups of 10+ would step up to a coach format)."
            },
            "unesco_fit": {
              "old": 0.2,
              "new": 0.3,
              "reasoning": "VERIFIED — modest upward calibration. Route 3 visits Korean Folk Village (Jultagi tightrope is UNESCO ICH, but the village itself isn't UNESCO World Heritage). Custom Route can include Suwon Hwaseong (UNESCO 1997). Weighted ~0.30 — modest UNESCO content compared to a Jeju or Gyeongju trip."
            },
            "iconic_landmark_fit": {
              "old": 0.8,
              "new": 0.85,
              "reasoning": "VERIFIED — Nami Island, Garden of Morning Calm, DMZ 3rd Tunnel, Everland T Express are all iconic landmarks of the Seoul-area touring circuit. 0.85 calibrated."
            },
            "first_time_fit": {
              "old": 0.8,
              "new": 0.85,
              "reasoning": "VERIFIED — for a first-time Seoul visitor with kids, Route 1 (Gapyeong) or Route 3 (Everland) deliver maximum recognizable content. 0.85 calibrated up from 0.80."
            },
            "scenic_level": {
              "old": 0.8,
              "new": 0.8,
              "reasoning": "Verified — Gapyeong nature loop is high scenic; DMZ is institutional rather than scenic; Everland is theme-park visual rather than scenic. Average ~0.80 maintained."
            },
            "walking_level": {
              "old": 0.4,
              "new": 0.55,
              "reasoning": "VERIFIED — was significantly underestimated. Route 1: 3 km Nami walk + Morning Calm 1.5-2hr garden + Petite France slopes (~0.55). Route 2: 3rd Tunnel ramp + Paju Outlets walking (~0.50). Route 3: Everland 5-10 km hilly OR Folk Village 5-7 km flat (~0.75). Average ~0.55, materially higher than previous 0.40."
            },
            "indoor_ratio": {
              "old": 0.5,
              "new": 0.4,
              "reasoning": "VERIFIED — weighted across routes. Route 1: low indoor (~0.20 — Petite France interiors + Morning Calm cafés). Route 2: moderate (~0.45 — 3rd Tunnel underground + Paju Outlets covered shopping). Route 3: moderate (~0.30 Everland + 0.20 Folk Village = ~0.25). Average ~0.40, lower than previous 0.50."
            },
            "weather_sensitivity": {
              "old": 0.4,
              "new": 0.5,
              "reasoning": "VERIFIED — calibrated up from 0.40. Route 1 (Gapyeong outdoor gardens + island) has high weather sensitivity. Route 2 has indoor DMZ + Paju Outlets fallback. Route 3 Everland is outdoor theme park. Average ~0.50."
            },
            "shopping_fit": {
              "old": 1.0,
              "new": 0.7,
              "reasoning": "VERIFIED — only Route 2 (Paju Outlets) has flag邮轮 shopping. Routes 1, 3 have minimal shopping. Custom Route can max if specifically requested. Weighted ~0.70, materially lower than the previous 1.0 which assumed Route 2 always selected."
            },
            "family_fit": {
              "old": 1.0,
              "new": 1.0,
              "reasoning": "Verified — Routes 1 and 3 are best-in-class for families with kids. Route 2 less so but still doable. Maintained at 1.0."
            },
            "premium_fit": {

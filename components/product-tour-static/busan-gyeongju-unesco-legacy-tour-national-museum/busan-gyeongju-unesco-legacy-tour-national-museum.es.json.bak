            "description": "Su confirmación de reserva llega al instante con opciones de estación (Busán/Seomyeon/Haeundae) y el resumen del itinerario."
          },
          {
            "timing": "12 horas antes",
            "title": "Recordatorio 12 horas antes",
            "detail": "Estado de Bulguksa (posibles cierres por eventos) y condiciones.",
            "description": "Enviamos una actualización meteorológica y nota de ruta estacional para mantener el plan del día actualizado."
          },
          {
            "timing": "La noche anterior",
            "title": "Información final de recogida",
            "detail": "Punto de encuentro y contacto del guía.",
            "description": "Su conductor-guía confirma el número de matrícula de la furgoneta y la hora exacta de recogida la noche anterior."
          },
          {
            "timing": "La mañana del tour",
            "title": "Notas del día del tour",
            "detail": "Horarios de apertura del museo y de la iluminación del puente.",
            "description": "Un mensaje matutino confirma su estación y señala cualquier tráfico en la Autopista del Mar del Este."
          },
          {
            "timing": "Durante el tour",
            "title": "Consejos parada a parada",
            "detail": "Recomendaciones de almuerzo y ángulos de foto en Woljeonggyo.",
            "description": "El guía narra en profundidad — seis Tesoros Nacionales en Bulguksa, corona de oro en el museo."
          },
          {
            "timing": "Tras el tour",
            "title": "Atención posventa",
            "detail": "Solicitud de valoración tras el tour.",
            "description": "Tras la llegada se envía una breve encuesta de valoración; también hacemos seguimiento de cualquier pregunta sobre el viaje posterior en Gyeongju."
          }

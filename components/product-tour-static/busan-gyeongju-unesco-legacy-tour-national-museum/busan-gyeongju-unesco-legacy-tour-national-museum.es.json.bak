            ],
            "timeUsed": [
              "Recogidas escalonadas ~08:00-08:40",
              "Desplazamiento a Gyeongju — ~1 hora"
            ],
            "whyOnRoute": "El esquema de recogida en tres estaciones es el formato estándar para tours en grupo reducido con destino a Gyeongju y coincide con el de los operadores competidores. Empezar por Haeundae como última parada minimiza el trayecto en vacío hasta el bosque de bambú de Ahopsan en Gijang-gun (primera parada del día), preservando así el espectacular final al atardecer en el puente Woljeonggyo.",
            "_poi_meta": {
              "poi_key": "OPS_busan_subway_pickup",
              "verified": true,
              "match": "transit_placeholder",
              "kb_version": "1.15",

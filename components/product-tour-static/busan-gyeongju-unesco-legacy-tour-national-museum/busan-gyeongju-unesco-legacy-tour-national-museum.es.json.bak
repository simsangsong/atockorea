  "staticQuestions": [
    {
      "id": "q-bridge-night-view",
      "question": "¿Está iluminado el puente cuando visitamos?",
      "answer": "Sí — la iluminación de Woljeonggyo se enciende al anochecer. El tour llega ~17:30-18:00, durante la hora dorada antes del encendido completo. En los días con más luz (junio-julio), puede que la iluminación plena sea posterior a la salida."
    },
    {
      "id": "q-vs-ancient-capital",
      "question": "(Consulte las preguntas frecuentes al reservar)",
      "answer": "Para más información, contacte a AtoC Korea al reservar."
    },
    {
      "id": "q-seokguram",
      "question": "(Consulte las preguntas frecuentes al reservar)",
      "answer": "Para más información, contacte a AtoC Korea al reservar."
    },
    {
      "id": "q-admissions",
      "question": "¿Las entradas están incluidas?",
      "answer": "Sí. Todas las entradas están incluidas: Bulguksa (₩6.000), Museo Nacional de Gyeongju (gratuito), Ahopsan, Gyochon y Woljeonggyo (gratuitos)."
    },
    {
      "id": "q-museum-language",
      "question": "¿Hay señalización en inglés en el museo?",
      "answer": "Sí. El Museo Nacional de Gyeongju tiene señalización bilingüe (coreano/inglés) en las piezas principales. El guía explica los hitos clave (Corona de Oro, Caballo Celestial, Campana de Seongdeok)."
    },
    {
      "id": "q-bulguksa-photography",
      "question": "¿Se puede fotografiar en Bulguksa?",
      "answer": "Sí, en todas las áreas exteriores e interiores de patio. El interior de los pabellones principales puede tener restricciones. El guía le indicará qué está permitido."
    },
    {
      "id": "q-bulguksa-stairs",
      "question": "¿Tengo que subir las escalinatas de piedra de Bulguksa?",
      "answer": "Las escalinatas Cheongungyo/Baegungyo (Tesoro Nacional n.° 23) están reservadas a monjes y no están abiertas al público. Los visitantes usan las rampas laterales de acceso moderno. Las escalinatas se pueden ver y fotografiar desde la distancia."
    },
    {
      "id": "q-vegetarian",
      "question": "¿Hay opciones vegetarianas para el almuerzo?",
      "answer": "Sí. El Gyeongju Ssambap puede prepararse sin carne a petición. Comuníquelo al guía al reservar."
    },
    {
      "id": "q-rain",
      "question": "¿Qué pasa si llueve?",
      "answer": "El tour sigue normalmente. El museo tiene aire acondicionado (ideal con lluvia). Bulguksa bajo la lluvia tiene una atmósfera única. Con tifón: cancelación total con reembolso."
    },
    {
      "id": "first-time",
      "question": "¿Es buena opción para quienes visitan Gyeongju por primera vez?",
      "answer": "Sí — es el tour más completo de Gyeongju disponible desde Busan, con el Museo Nacional incluido. Cubre el UNESCO (Bulguksa), el mayor tesoro arqueológico (corona de oro Silla), la arquitectura doméstica joseonesa (Gyochon) y el icono fotográfico (Woljeonggyo)."
    },
    {
      "id": "walking",
      "question": "¿Cuánto hay que caminar?",
      "answer": "Moderado. Total: ~4-5 km. Bulguksa es la sección más activa (pendientes y escalones de acceso). Ahopsan, museo, Gyochon y Woljeonggyo son moderados o llanos."
    },
    {
      "id": "family",
      "question": "¿Es adecuado para familias con niños?",
      "answer": "Sí para niños de 8+ años interesados en historia y arte. El museo puede ser largo para niños más pequeños. Bulguksa y Woljeonggyo son especialmente fotogénicos para familias."
    },
    {
      "id": "seniors",
      "question": "¿Pueden participar personas mayores cómodamente?",
      "answer": "Sí para mayores activos. Bulguksa tiene rampas de acceso modernas (las escalinatas históricas no se usan). El museo es completamente plano. Gyochon y Woljeonggyo son llanos."
    },
    {
      "id": "children",
      "question": "¿Cuál es la edad mínima recomendada?",
      "answer": "A partir de 8 años para aprovechar el contenido del museo y Bulguksa. Para niños más pequeños, el C1 (Busan) o el C4 (crucero) son más visuales y menos históricos."
    }
  ],

  "staticQuestions": [
    {
      "id": "q-bridge-night-view",
      "question": "방문 시 월정교 야간 조명을 볼 수 있나요?",
      "answer": "계절에 따라 다릅니다. 월정교는 연중 일몰부터 약 22:00까지 조명이 켜지지만, 이 투어는 일몰 전에 월정교에 도착합니다. 늦여름~초가을(일몰이 이른 시기)에는 황혼 조명을 볼 수 있습니다."
    },
    {
      "id": "q-vs-ancient-capital",
      "question": "'경주 고도 투어(부산 출발)'와 어떻게 다른가요?",
      "answer": "두 투어 모두 아홉산 → 불국사 → 박물관 → 교촌 → 월정교 코스로 진행됩니다. '유네스코 레거시' 투어는 박물관 체류 시간(75분)과 가이드 설명이 더 심층적입니다. '고도 투어'는 일정 속도가 느리고 더 일찍 부산에 귀환합니다."
    },
    {
      "id": "q-seokguram",
      "question": "석굴암은 왜 포함되지 않나요?",
      "answer": "석굴암은 불국사와 같은 유네스코 등재이지만 산 위 8km 거리에 위치하며, 주차가 좁고 이동 시간이 길어 당일 일정에 포함하기 어렵습니다. 석굴암을 꼭 보고 싶으신 경우 프라이빗 투어로 문의하세요."
    },
    {
      "id": "q-admissions",
      "question": "입장료가 포함되어 있나요?",
      "answer": "대부분 무료입니다. 아홉산숲 입장료(₩5,000, 현장 지불)만 별도입니다. 불국사는 2023년 5월부터 무료, 국립경주박물관·교촌·월정교는 무료입니다."
    },
    {
      "id": "q-museum-language",
      "question": "박물관 내 영어 안내가 있나요?",
      "answer": "네, 국립경주박물관 3개 상설전시관(신라역사관·신라미술관·야외유물관) 전체에 영어·중국어 전시 패널이 있습니다."
    },
    {
      "id": "q-bulguksa-photography",
      "question": "불국사에서 사진을 찍을 수 있나요?",
      "answer": "네, 경내 전체(두 탑 포함, 하층 석교)에서 사진 촬영이 가능합니다. 플래시와 삼각대는 피해 주세요."
    },
    {
      "id": "q-bulguksa-stairs",
      "question": "불국사 33계단 석교를 올라야 하나요?",
      "answer": "아닙니다. 청운교·백운교와 연화교·칠보교는 국보로 보존되어 관람 전용입니다. 방문객은 계단 옆 현대식 입구를 이용합니다."
    },
    {
      "id": "q-vegetarian",
      "question": "채식 점심 옵션이 있나요?",
      "answer": "네, 경주 쌈밥 정식은 채소 반찬이 많아 고기 없이도 식사 구성이 가능합니다. 현장에서 가이드가 채식 요청을 도와드립니다."
    },
    {
      "id": "q-rain",
      "question": "비가 오면 어떻게 되나요?",
      "answer": "가벼운 비: 예정대로 진행. 강우 시: 불국사 석조 계단이 미끄러워지고 아홉산 길이 진흙 상태가 될 수 있습니다. 박물관과 교촌은 실내·실외 혼합이라 대부분 진행 가능합니다."
    },
    {
      "id": "first-time",
      "question": "경주를 처음 방문하는 분에게 적합한가요?",
      "answer": "네, 경주 유네스코·문화 명소를 하루에 균형 있게 방문할 수 있는 투어입니다."
    },
    {
      "id": "walking",
      "question": "도보 이동이 얼마나 되나요?",
      "answer": "총 약 4~5km. 불국사가 가장 활동적인 구간(고르지 않은 석재, 완만한 오르막). 박물관은 실내 평지. 교촌·월정교는 가볍습니다."
    },
    {
      "id": "family",
      "question": "어린이와 함께하기 적합한가요?",
      "answer": "만 8세 이상, 하루 일정을 소화할 수 있는 어린이에게 적합합니다. 박물관 금관과 성덕대왕신종은 어린이들이 특히 좋아하는 전시물입니다."
    },
    {
      "id": "seniors",
      "question": "어르신도 참여할 수 있나요?",
      "answer": "불국사 4~5km 도보와 고르지 않은 석재를 소화할 수 있는 활동적인 어르신께 권장합니다. 일정 속도는 여유 있게 진행됩니다."
    },
    {
      "id": "children",
      "question": "권장 최소 연령은 몇 세인가요?",
      "answer": "만 8세 이상, 하루 일정 속도와 도보 활동이 가능한 어린이에게 적합합니다."
    }
  ],

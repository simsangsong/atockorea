  "matching_metadata": {
    "matching_schema": "tour_matching_profiles_embedded_v2",
    "embedded_for": "atockorea_tour_marketplace",
    "source_of_truth_note": "Internal note: product profile checked against current route-selection rules. Single fixed route; no route option overrides.",
    "audit_summary": "Southwest-Jeju Hydrangea Festival route — 9-hr small-group minicoach loop. 5 substantive POI anchors + 1 compound-stop pairing: 1 west-coast emerald beach (Hyeopjae) + 1 120-min hydrangea festival anchor (Hallim Park, June Hydrangea Festival, 9 themed gardens + 2 lava-tube limestone caves) + 1 compound stop (Jusangjeolli columnar + Cheonjeyeon waterfall, Natural Monuments 443 + 378) + 1 hydrangea tunnel anchor (Camellia Hill — 172,000 m², Korea's earliest hydrangeas) + 1 tea-culture finale (Osulloc / Amorepacific). Designed for **June peak hydrangea window (June 10–25)** with Hallim caves + Camellia Hall + Osulloc museum as the 3-tier indoor weather-fallback stack. **Catalog-novel pattern**: Jusangjeolli+Cheonjeyeon compound stop is the first of its kind in the catalog. Cross-batch reuse: 3 of 5 substantive bodies imported verbatim (15a T2 Hyeopjae, 15a T1 Camellia Hill, 14a T2 Osulloc); Hallim Park authored fresh + compound stop authored fresh.",
    "score_rationale": {
      "high_scores": {
        "southwest_jeju_fit=1.0": "All 5 substantive stops are on the southwest corridor (Hallim, Jungmun, Andeok, Seogwang)",
        "hydrangea_festival_anchor_count=3": "Hallim June Hydrangea + Camellia Hill hydrangea tunnel + Osulloc tea-garden green tone",
        "hydrangea_tunnel_visit=True": "Unique to this route — Camellia Hill's signature pergola tunnel",
        "natural_monument_anchor_count=2": "Jusangjeolli (NM 443, 2005) + Cheonjeyeon (NM 378, 1993)",
        "two_dimensional_caves_fit=1.0": "Hallim's Hyeopjaegul + Ssangyonggul are uniquely classified as the only lava-tube + limestone caves in the world",
        "honeymoon_fit=1.0": "Camellia Hill is one of Korea's top wedding-snap photo destinations + lower-impact ritmo del recorrido",
        "compound_stop_count=1": "Jusangjeolli+Cheonjeyeon compound is a catalog-novel pattern"
      },
      "low_scores": {
        "stair_climb_demand=0.2": "No tuff-cone climb (Seongsan) — only Cheonjeyeon's 50-step descent + Hallim's gentle cave stairs",
        "tuff_cone_climb_fit=0.0": "No tuff cone on this route — sister tour east route has Seongsan",
        "winter_visitors_seeking_floral_peak": "Hydrangea peak is June; winter visitors get Camellia Hill camellia bloom but not hydrangea tunnel",
        "private_tour_fit=0.05": "Fixed small-group itinerary preserves the operator's cave timing + lunch pairing"
      }
    },

  "staticQuestions": [
    {
      "id": "first-time",
      "question": "¿Es buena opción para primera visita en verano?",
      "answer": "Sí, especialmente en junio-julio. Combina el Túnel de Hortensias (único en Jeju) con el acantilado UNESCO, las cascadas y los campos de té."
    },
    {
      "id": "season-timing",
      "question": "¿Cuándo es exactamente la temporada de hortensias?",
      "answer": "Las hortensias del suroeste de Jeju florecen entre junio y agosto, con el pico en la última semana de junio y la primera de julio."
    },
    {
      "id": "rain",
      "question": "¿Qué pasa si llueve?",
      "answer": "Las hortensias mojadas son especialmente fotogénicas (el azul se intensifica). Con tifón: reembolso total."
    },
    {
      "id": "two-hydrangea-stops",
      "question": "¿Por qué dos paradas de hortensias?",
      "answer": "Hallim Park tiene el contexto de cuevas de lava (hortensias + basalto negro). Camellia Hill tiene el famoso Túnel de Hortensias (dosel envolvente). Son experiencias completamente distintas."
    },
    {
      "id": "kids",
      "question": "¿Es adecuado para niños?",
      "answer": "Sí para niños de 6+ años. El Túnel de Hortensias es especialmente popular entre niños."
    },
    {
      "id": "seniors",
      "question": "¿Es adecuado para personas mayores?",
      "answer": "Sí para mayores activos. Las principales paradas de hortensias son moderadas."
    },
    {
      "id": "pickup-area",
      "question": "¿Dónde es la recogida?",
      "answer": "En los puntos habituales de Ciudad de Jeju. El guía confirma al reservar."
    },
    {
      "id": "lunch",
      "question": "¿El almuerzo está incluido?",
      "answer": "No. Almuerzo por su cuenta (~₩12.000-15.000/persona)."
    },
    {
      "id": "admission-fees",
      "question": "¿Las entradas están incluidas?",
      "answer": "Sí: Hallim Park, Jusangjeolli (₩2.000), Cheonjeyeon (₩2.500), Camellia Hill, — todas incluidas."
    },
    {
      "id": "tea-museum",
      "question": "¿ está incluido?",
      "answer": "Sí. La entrada al Museo de Té y los campos de té es gratuita y está incluida en el tour."
    },
    {
      "id": "compare-west-south-year-round",
      "question": "(Consulte las preguntas frecuentes al reservar)",
      "answer": "Para más información, contacte a AtoC Korea al reservar."
    }
  ],

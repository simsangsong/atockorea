      "guests_with_severe_pollen_allergies"
    ],
    "differentiation_vs_east_hydrangea_sister": "Same 'hydrangea festival' product family, but **southwest garden-plus-geology emphasis**: 3 garden anchors (Hallim + Camellia Hill + Osulloc tea-fields) + 1 compound geology stop (Jusangjeolli+Cheonjeyeon) + 1 west-coast beach (Hyeopjae). The east sister covers **Hamdeok beach + Seongeup Joseon heritage + triple-UNESCO Seongsan + Ilchul Land + Hueree** — a more UNESCO-and-heritage-coded, higher-climb route. Booking matrix: guests with strong wedding-photo or hydrangea-tunnel interest + lower mobility tolerance + multi-garden preference should book southwest; guests with strong UNESCO + Joseon heritage interest + willing to climb Seongsan should book east. **Both routes share Camellia Hill peak alignment in mid-June**, so the operator can offer parallel departures for both routes simultaneously during peak hydrangea weeks.",
    "seasonal_window": {
      "best_months": [
        "June (peak hydrangea)",
        "May (early hydrangea + Camellia Hill greenhouse)",
        "April (Camellia Hill spring start)",
        "October"
      ],
      "good_months": [
        "March",
        "September",
        "November (Camellia Hill camellia start)"
      ],
      "low_season_months": [
        "December",
        "January",
        "February"
      ],
      "snow_closure_risk": "None — west-coast route is snow-resilient",
      "typhoon_window": "August — typhoon-track season; tour reschedule policy applies"
    },
    "kb_anchor_version": "1.21"
  },

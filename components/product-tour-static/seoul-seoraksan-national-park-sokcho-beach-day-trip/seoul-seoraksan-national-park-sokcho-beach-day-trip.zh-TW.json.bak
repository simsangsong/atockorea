    "routeLogicSections": [
      {
        "title": "為何如此安排路線",
        "icon": "route",
        "iconBg": "bg-sky-50/80",
        "iconColor": "text-sky-600",
        "items": [
          {
            "label": "山區時間比標準行程更充裕",
            "detail": "在雪嶽山停留3小時，足以步行至秘仙臺、搭乘纜車，而不只是匆匆看一眼入口。許多東海岸行程與三個其他景點配對，結果在公園本身只留90分鐘。"
          },
          {
            "label": "真正的束草美食，而非觀光套餐",
            "detail": "觀光水產市場是束草人真正用餐的地方——鹹鏡道風格難民料理、東海生魚片、甘辣炸雞。自由時間讓您自選食物，而非坐等固定巴士午餐。"
          },
          {
            "label": "比山嶽＋南怡島的組合更清晰",
            "detail": "其他東向行程將雪嶽山與南怡島或晨靜樹木園組合成13至14小時的全日行程。本行程緊守束草軸線——山嶽、市場、海灘——節奏更緊湊，不那麼倉促。"
          },
          {
            "label": "四季皆適宜",
            "detail": "秋季紅葉是最熱門季節，但同樣路線在夏季海灘日、冬季雪景及春日新綠同樣精彩。市場在任何天氣下都人氣旺盛，而巴士也省去了DIY旅客花在鐵路和巴士換乘上的半天時間。"
          }
        ]
      },
      {
        "title": "步行負擔的真實感受",
        "icon": "footprints",
        "iconBg": "bg-emerald-50/80",
        "iconColor": "text-emerald-600",
        "items": [
          {
            "label": "雪嶽山鋪設核心路段",
            "detail": "素公園入口至神興寺及纜車底站為鋪設步道，適合嬰兒車通行。單程約600公尺，來回步行15至20分鐘。"
          },
          {
            "label": "秘仙臺可選平坦步道",
            "detail": "沿溪流行走，單程1.5公里——平坦、路標清晰、無需爬坡。為雪嶽山停留增加約45分鐘。"
          },
          {
            "label": "束草海水浴場沙灘",
            "detail": "平坦但鬆軟沙地，1公里主要路段對行動不便的旅客可能造成疲勞。永郎海岸公路提供鋪設替代路線。"
          }
        ]
      },
      {
        "title": "天氣與季節變化",
        "icon": "cloud-sun",
        "iconBg": "bg-amber-50/80",
        "iconColor": "text-amber-600",
        "items": [
          {
            "label": "秋季紅葉高峰",
            "detail": "10月中至11月初是雪嶽山的代表性季節。纜車常滿員——抵達後立即購票，或直接略過。"
          },
          {
            "label": "冬季雪景",
            "detail": "12至2月：神興寺及低海拔步道通常仍可行走；強風日纜車可能暫停。市場有完整遮蔭。束草海水浴場僅供拍照，不宜遠行。"
          },
          {
            "label": "遊泳時段：7月中至8月下旬",
            "detail": "唯一束草海灘設有救生員的時段。時段之外水溫寒冷，僅供散步。"
          }
        ]
      }
    ]
  },

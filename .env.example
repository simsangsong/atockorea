# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local (it is in .gitignore).

# 기본: localhost(127.0.0.1, ::1)만 실제 홈·투어 UI. 프로덕션/프리뷰 URL 공개 시:
# SITE_HOME_PUBLIC=true

# App URL — 결제 후 리다이렉트 등에 사용. 로컬은 localhost, 프로덕션은 실제 사이트 주소로 설정.
# NEXT_PUBLIC_APP_URL=https://www.atockorea.com
# 플래그십 소그룹 투어 URL(홈 CTA 등)은 코드 상수: lib/home/home-cta-routes.ts (`/tour/east-jeju-signature-small-group`).
# (미설정 시 기본값: http://localhost:3000)

# Stripe (required for checkout)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: for webhook (payment confirmation)
# STRIPE_WEBHOOK_SECRET=

# Resend (예약 확정 메일 등 발송). https://resend.com
# RESEND_API_KEY=re_...
# 발신 주소: Resend에서 인증한 도메인으로 설정 (미설정 시 support@atockorea.com 사용)
# RESEND_FROM_EMAIL=AtoCKorea <noreply@atockorea.com>

# Exchange rate API (optional). Get a free key at https://www.exchangerate-api.com/
# If not set, the app uses the free open.er-api.com endpoint (no key).
EXCHANGE_RATE_API_KEY=

# Android app (Capacitor): URL loaded in the app WebView. Set when running `npx cap sync android`.
# If unset, capacitor.config.ts uses https://www.atockorea.com
# CAPACITOR_SERVER_URL=https://www.atockorea.com

# Homepage hero (mobile): muted intro video URL, e.g. Cloudinary delivery URL (.mp4).
# Leave unset to show only the 16:9 text area.
# NEXT_PUBLIC_HERO_INTRO_VIDEO_URL=

# /tour-product/east-signature-nature-core: Supabase에서 본문 로드 (마이그레이션·시드 적용 후)
# 미설정 또는 1이 아니면 번들 정적 뷰모델 사용
# TOUR_PRODUCT_USE_SUPABASE=1

# /tour-product/east-signature → /tour/[uuid]/checkout (Stripe). slug 조회 실패 시 폴백:
# TOUR_PRODUCT_EAST_SIGNATURE_TOUR_ID=uuid-from-supabase-tours-table
# TOUR_PRODUCT_EAST_SIGNATURE_UNIT_PRICE_USD=58
# (레거시) 원 단가만 있을 때: 환율로 USD 환산
# TOUR_PRODUCT_EAST_SIGNATURE_UNIT_PRICE_KRW=78300

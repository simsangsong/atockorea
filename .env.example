# Copy this file to .env.local and fill in your values.
# Do NOT commit .env.local (it is in .gitignore).

# ------------------------------------------------------------------------------
# Supabase CLI (Cursor/터미널에서 원격 DB에 SQL 실행, 마이그레이션 동기화)
# ------------------------------------------------------------------------------
# 설치는 package.json 의 devDependency `supabase` 로 포함됨. 워크스페이스 루트에서:
#
#   npx supabase login
#   npx supabase link --project-ref <ref>
#     → ref 는 NEXT_PUBLIC_SUPABASE_URL 의 https://<ref>.supabase.co 에서 확인
#
# 원격 프로젝트에 SQL 실행(upsert·수정·검증용 스크립트는 supabase/manual/ 참고):
#   npm run db:exec -- -f supabase/manual/your-script.sql
#
# 또는 Cursor에서 .sql 파일을 연 뒤: Terminal → Run Task → "Supabase: SQL 실행 (linked, 현재 파일)"
#
# 스키마/마이그레이션:
#   npm run db:pull          # 원격 → 로컬 declarative 스키마(상황에 따라 마이그레이션 재정렬 주의)
#   npm run db:push          # supabase/migrations → 원격 적용 (운영 적용 전 반드시 검토)
#   npm run db:diff          # 로컬 마이그레이션과 linked 원격의 차이 확인
#
# Postgres 타입(TS): npm run db:types  → lib/database.types.ts 생성
#
# 원격 테이블 UI 편집: https://supabase.com/dashboard/project/<ref>/editor
# 로컬 전체 스택(Docker 필요): npm run db:start 후 Studio 기본 URL http://127.0.0.1:54323
#
# (선택) CI/대화형 없이 인증만 쓸 때 ACCESS_TOKEN 등은 Supabase 문서의 CLI 로그인 절차를 따를 것.

# 기본: localhost(127.0.0.1, ::1)만 실제 홈·투어 UI. 프로덕션/프리뷰 URL 공개 시:
# SITE_HOME_PUBLIC=true

# App URL — 결제 후 리다이렉트 등에 사용. 로컬은 localhost, 프로덕션은 실제 사이트 주소로 설정.
# NEXT_PUBLIC_APP_URL=https://www.atockorea.com
# 플래그십 소그룹 투어 URL(홈 CTA 등)은 코드 상수: lib/home/home-cta-routes.ts (`/tour/east-jeju-signature-small-group`).
# (미설정 시 기본값: http://localhost:3000)

# 리뷰 작성 플로우 샌드박스 — `/reviews/preview` 에서만 로컬 UX 확인용 (모의 예약·저장 없음). 프로덕션 빌드에서는 설정하지 마세요.
# 로컬에서는 보통 http://localhost:3000/reviews/preview 로 접속 (기본 dev 서버는 HTTPS 아님).
# NEXT_PUBLIC_REVIEW_FLOW_PREVIEW=1

# Stripe (required for checkout)
# Get keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: for webhook (payment confirmation)
# STRIPE_WEBHOOK_SECRET=

# Resend (예약 확정 메일 등 발송). https://resend.com
# RESEND_API_KEY=re_...
# 발신 주소: Resend에서 인증한 도메인으로 설정 (미설정 시 support@atockorea.com 사용)
# RESEND_FROM_EMAIL=AtoCKorea <noreply@atockorea.com>

# Exchange rate API (optional). Get a free key at https://www.exchangerate-api.com/
# If not set, the app uses the free open.er-api.com endpoint (no key).
EXCHANGE_RATE_API_KEY=

# Android app (Capacitor): URL loaded in the app WebView. Set when running `npx cap sync android`.
# If unset, capacitor.config.ts uses https://www.atockorea.com
# CAPACITOR_SERVER_URL=https://www.atockorea.com

# Homepage hero (mobile): muted intro video URL, e.g. Cloudinary delivery URL (.mp4).
# Leave unset to show only the 16:9 text area.
# NEXT_PUBLIC_HERO_INTRO_VIDEO_URL=

# /tour-product/east-signature-nature-core: Supabase에서 본문 로드 (마이그레이션·시드 적용 후)
# 미설정 또는 1이 아니면 번들 정적 뷰모델 사용
# TOUR_PRODUCT_USE_SUPABASE=1

# ------------------------------------------------------------------------------
# Tour product matcher (`/match` + Home v2 hero planner)
# Tour product detail — AI floating assistant (`/tour-product/*`, `/api/tour-product/assistant`)
# ------------------------------------------------------------------------------
# Gemini (Google AI Studio) — 매칭 파이프라인 + 투어 상세 위젯 공통.
# 미설정 시: 매칭은 deterministic-only, 위젯은 전송 시 안내만 표시.
# 키 발급: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=
# Optional: 위젯만 다른 모델 (기본 `gemini-2.5-flash`, 매칭용 `gemini-match-explanation.ts`와 동일 기본값)
# GEMINI_TOUR_PRODUCT_ASSISTANT_MODEL=

# 매칭 프로파일 데이터 소스. 기본 `auto`: Supabase 먼저, 실패/0건이면 in-app seed 폴백.
# 허용값: auto | seed | supabase
# TOUR_MATCH_PROFILE_SOURCE=auto

# 점수 가중치 세트. 기본 `default`. 실험 세트: `v1`.
# TOUR_MATCH_WEIGHT_SET=default

# 1 이면 매칭 라우트에 verbose trace 로그 출력 (개발/QA 전용).
# TOUR_MATCH_TRACE_LOG=

# /tour-product/east-signature → /tour/[uuid]/checkout (Stripe). slug 조회 실패 시 폴백:
# TOUR_PRODUCT_EAST_SIGNATURE_TOUR_ID=uuid-from-supabase-tours-table
# TOUR_PRODUCT_EAST_SIGNATURE_UNIT_PRICE_USD=58
# (레거시) 원 단가만 있을 때: 환율로 USD 환산
# TOUR_PRODUCT_EAST_SIGNATURE_UNIT_PRICE_KRW=78300
